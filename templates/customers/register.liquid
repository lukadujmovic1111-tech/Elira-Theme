<section class="section account-page account-page--narrow">
  <div class="container container--narrow">
    <div class="auth-card">
      <h1 class="section-title">{{ 'customer.register.title' | t }}</h1>
      <p class="section-sub">{{ 'customer.register.text' | t }}</p>

      {%- form 'create_customer', class: 'auth-form' -%}
        {%- if form.errors -%}
          <p class="form-error">{{ form.errors | default_errors }}</p>
        {%- endif -%}
        <div class="contact-form__row">
          <div class="form-field">
            <label for="RegisterFirstName">{{ 'customer.register.first_name' | t }}</label>
            <input type="text" id="RegisterFirstName" name="customer[first_name]" autocomplete="given-name">
          </div>
          <div class="form-field">
            <label for="RegisterLastName">{{ 'customer.register.last_name' | t }}</label>
            <input type="text" id="RegisterLastName" name="customer[last_name]" autocomplete="family-name">
          </div>
        </div>
        <div class="form-field">
          <label for="RegisterEmail">{{ 'general.forms.email' | t }}</label>
          <input type="email" id="RegisterEmail" name="customer[email]" autocomplete="email" required>
        </div>
        <div class="form-field">
          <label for="RegisterPassword">{{ 'customer.login.password' | t }}</label>
          <input type="password" id="RegisterPassword" name="customer[password]" autocomplete="new-password" required>
        </div>
        <button type="submit" class="btn btn--primary btn--full">{{ 'customer.register.submit' | t }}</button>
      {%- endform -%}

      <div class="auth-card__links">
        <a href="{{ routes.account_login_url }}" class="link-underline">{{ 'customer.register.have_account' | t }}</a>
      </div>
    </div>
  </div>
</section>
