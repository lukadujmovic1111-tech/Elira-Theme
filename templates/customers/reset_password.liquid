<section class="section account-page account-page--narrow">
  <div class="container container--narrow">
    <div class="auth-card">
      <h1 class="section-title">{{ 'customer.reset_password.title' | t }}</h1>
      <p class="section-sub">{{ 'customer.reset_password.text' | t }}</p>

      {%- form 'reset_customer_password', class: 'auth-form' -%}
        {%- if form.errors -%}
          <p class="form-error">{{ form.errors | default_errors }}</p>
        {%- endif -%}
        <div class="form-field">
          <label for="ResetPassword">{{ 'customer.reset_password.password' | t }}</label>
          <input type="password" id="ResetPassword" name="customer[password]" autocomplete="new-password" required>
        </div>
        <div class="form-field">
          <label for="ResetPasswordConfirm">{{ 'customer.reset_password.password_confirm' | t }}</label>
          <input type="password" id="ResetPasswordConfirm" name="customer[password_confirmation]" autocomplete="new-password" required>
        </div>
        <button type="submit" class="btn btn--primary btn--full">{{ 'customer.reset_password.submit' | t }}</button>
      {%- endform -%}
    </div>
  </div>
</section>
