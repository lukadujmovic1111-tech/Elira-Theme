<section class="section account-page account-page--narrow">
  <div class="container container--narrow">

    <div class="auth-card" data-login-view>
      <h1 class="section-title">{{ 'customer.login.title' | t }}</h1>

      {%- form 'customer_login', class: 'auth-form' -%}
        {%- if form.errors -%}
          <p class="form-error">{{ form.errors | default_errors }}</p>
        {%- endif -%}
        <div class="form-field">
          <label for="CustomerEmail">{{ 'general.forms.email' | t }}</label>
          <input type="email" id="CustomerEmail" name="customer[email]" autocomplete="email" required>
        </div>
        <div class="form-field">
          <label for="CustomerPassword">{{ 'customer.login.password' | t }}</label>
          <input type="password" id="CustomerPassword" name="customer[password]" autocomplete="current-password" required>
        </div>
        <button type="submit" class="btn btn--primary btn--full">{{ 'customer.login.submit' | t }}</button>
      {%- endform -%}

      <div class="auth-card__links">
        <button type="button" class="link-underline" data-recover-toggle>{{ 'customer.login.forgot' | t }}</button>
        <a href="{{ routes.account_register_url }}" class="link-underline">{{ 'customer.register.title' | t }}</a>
      </div>
    </div>

    <div class="auth-card" data-recover-view hidden>
      <h2 class="section-title">{{ 'customer.recover.title' | t }}</h2>
      <p class="section-sub">{{ 'customer.recover.text' | t }}</p>

      {%- form 'recover_customer_password', class: 'auth-form' -%}
        {%- if form.posted_successfully? -%}
          <p class="form-success">{% render 'icon', name: 'check', size: 16 %} {{ 'customer.recover.success' | t }}</p>
        {%- endif -%}
        {%- if form.errors -%}
          <p class="form-error">{{ form.errors | default_errors }}</p>
        {%- endif -%}
        <div class="form-field">
          <label for="RecoverEmail">{{ 'general.forms.email' | t }}</label>
          <input type="email" id="RecoverEmail" name="email" autocomplete="email" required>
        </div>
        <button type="submit" class="btn btn--primary btn--full">{{ 'customer.recover.submit' | t }}</button>
      {%- endform -%}

      <div class="auth-card__links">
        <button type="button" class="link-underline" data-recover-toggle>{{ 'customer.recover.back' | t }}</button>
      </div>
    </div>

  </div>
</section>

<script>
  (function () {
    var toggles = document.querySelectorAll('[data-recover-toggle]');
    var loginView = document.querySelector('[data-login-view]');
    var recoverView = document.querySelector('[data-recover-view]');
    toggles.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var showRecover = recoverView.hasAttribute('hidden');
        recoverView.toggleAttribute('hidden', !showRecover);
        loginView.toggleAttribute('hidden', showRecover);
      });
    });
    if (window.location.hash === '#recover' && recoverView) {
      recoverView.removeAttribute('hidden');
      loginView.setAttribute('hidden', '');
    }
  })();
</script>
