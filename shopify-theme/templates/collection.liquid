<div class="collection-header">
  <div class="container">
    <h1>{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p>{{ collection.description | strip_html | truncate: 160 }}</p>
    {%- endif -%}
  </div>
</div>

<div class="container">
  <div class="collection-meta">
    <span class="collection-count">{{ collection.products_count }} Produkte</span>
    <div class="sort-bar">
      <span class="sort-label">Sortieren:</span>
      <select class="sort-select" id="sort-select" aria-label="Produkte sortieren">
        {%- assign sort_options = "manual,Empfohlen|best-selling,Bestseller|title-ascending,Name A–Z|title-descending,Name Z–A|price-ascending,Preis aufsteigend|price-descending,Preis absteigend|created-descending,Neueste zuerst" | split: '|' -%}
        {%- for opt in sort_options -%}
          {%- assign parts = opt | split: ',' -%}
          <option value="{{ parts[0] }}"{% if collection.sort_by == parts[0] %} selected{% endif %}>{{ parts[1] }}</option>
        {%- endfor -%}
      </select>
    </div>
  </div>

  <div class="collection-body">

    <!-- Filters sidebar -->
    <aside class="filters-sidebar">
      {%- unless collection.filters == blank -%}
        {%- for filter in collection.filters -%}
          <div class="filter-group">
            <button class="filter-toggle is-open">
              {{ filter.label }}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="filter-options">
              {%- for value in filter.values -%}
                <label class="filter-opt">
                  <input type="checkbox" name="{{ filter.param_name }}" value="{{ value.value }}"{% if value.active %} checked{% endif %}>
                  <span class="filter-check"></span>
                  <span>{{ value.label }} ({{ value.count }})</span>
                </label>
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <!-- Fallback static filters -->
        <div class="filter-group">
          <button class="filter-toggle is-open">
            Größe
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="filter-options">
            {%- for size in "XS,S,M,L,XL,XXL" | split: ',' -%}
              <label class="filter-opt"><input type="checkbox"><span class="filter-check"></span><span>{{ size }}</span></label>
            {%- endfor -%}
          </div>
        </div>
        <div class="filter-group">
          <button class="filter-toggle is-open">
            Preis
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="filter-options">
            <label class="filter-opt"><input type="checkbox"><span class="filter-check"></span><span>Unter €50</span></label>
            <label class="filter-opt"><input type="checkbox"><span class="filter-check"></span><span>€50 – €100</span></label>
            <label class="filter-opt"><input type="checkbox"><span class="filter-check"></span><span>€100 – €150</span></label>
            <label class="filter-opt"><input type="checkbox"><span class="filter-check"></span><span>Über €150</span></label>
          </div>
        </div>
      {%- endunless -%}
    </aside>

    <!-- Product grid -->
    <div>
      {%- paginate collection.products by 24 -%}
        <div class="products-grid reveal-group">
          {%- for product in collection.products -%}
            <div class="reveal">
              {%- render 'product-card', product: product -%}
            </div>
          {%- endfor -%}
          {%- if collection.products.size == 0 -%}
            <p style="grid-column:span 4;text-align:center;padding:4rem;color:var(--ink-40);font-size:0.9375rem;">
              Keine Produkte in dieser Kollektion gefunden.
            </p>
          {%- endif -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="page-btn" aria-label="Vorherige Seite">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
              </a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="page-btn{% if part.title == paginate.current_page %} is-active{% endif %}">{{ part.title }}</a>
              {%- else -%}
                <span class="page-btn is-active">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="page-btn" aria-label="Nächste Seite">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    </div>

  </div>
</div>

<script>
  document.getElementById('sort-select')?.addEventListener('change', function() {
    const url = new URL(window.location.href);
    url.searchParams.set('sort_by', this.value);
    window.location.href = url.toString();
  });
</script>
