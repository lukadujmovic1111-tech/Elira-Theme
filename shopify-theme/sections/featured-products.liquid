<section class="products-section">
  <div class="container">
    <div class="section-head-row">
      <h2 class="section-title">{{ section.settings.heading | default: 'Neue Arrivals' }}</h2>
      {%- if section.settings.view_all_url != blank -%}
        <a href="{{ section.settings.view_all_url }}" class="view-all">Alle anzeigen &rarr;</a>
      {%- endif -%}
    </div>

    {%- assign collection = collections[section.settings.collection] -%}
    {%- assign products_to_show = section.settings.products_count | default: 8 -%}

    <div class="products-grid">
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products limit: products_to_show -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..8) -%}
          <div class="prod-card">
            <div class="prod-img-wrap">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="prod-info">
              <p class="prod-name"><a href="#">Beispielprodukt {{ i }}</a></p>
              <p class="prod-price">€99</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Neue Arrivals" },
    { "type": "collection", "id": "collection", "label": "Kollektion" },
    { "type": "range", "id": "products_count", "min": 4, "max": 12, "step": 4, "label": "Anzahl Produkte", "default": 8 },
    { "type": "url", "id": "view_all_url", "label": "Alle anzeigen Link" }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
