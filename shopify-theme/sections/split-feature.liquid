<section class="split-section">
  {%- for block in section.blocks -%}
    <div class="split-item{% cycle '', ' split-reverse' %}" {{ block.shopify_attributes }}>
      <div class="split-img">
        {%- if block.settings.image != blank -%}
          <img src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.heading | escape }}" loading="lazy">
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      <div class="split-content">
        {%- if block.settings.eyebrow != blank -%}
          <span class="eyebrow">{{ block.settings.eyebrow }}</span>
        {%- endif -%}
        <h2>{{ block.settings.heading }}</h2>
        {%- if block.settings.text != blank -%}
          <p>{{ block.settings.text }}</p>
        {%- endif -%}
        {%- if block.settings.btn_label != blank -%}
          <a href="{{ block.settings.btn_url }}" class="btn btn-black">{{ block.settings.btn_label }}</a>
        {%- endif -%}
      </div>
    </div>
  {%- endfor -%}
</section>

{% schema %}
{
  "name": "Split Feature",
  "tag": "section",
  "blocks": [
    {
      "type": "item",
      "name": "Feature Item",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Bild" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Damen" },
        { "type": "text", "id": "heading", "label": "Überschrift", "default": "Flow State" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Für dein bestes Yoga- und Studio-Erlebnis." },
        { "type": "text", "id": "btn_label", "label": "Button Text", "default": "Jetzt shoppen" },
        { "type": "url", "id": "btn_url", "label": "Button Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Split Feature",
      "blocks": [
        { "type": "item", "settings": { "eyebrow": "Damen", "heading": "Flow State" } },
        { "type": "item", "settings": { "eyebrow": "Herren", "heading": "Train Hard" } }
      ]
    }
  ]
}
{% endschema %}
