<section class="promo-section">
  <div class="container">
    <div class="promo-grid">
      {%- assign large = section.blocks | where: "type", "large" | first -%}
      {%- if large -%}
        <div class="promo-large" {{ large.shopify_attributes }}>
          <div class="promo-bg" style="background-image:url('{{ large.settings.image | image_url: width: 900 }}')">
            <div class="promo-overlay"></div>
            <div class="promo-text">
              <h3>{{ large.settings.title }}</h3>
              {%- if large.settings.subtitle != blank -%}<p>{{ large.settings.subtitle }}</p>{%- endif -%}
              {%- if large.settings.btn_label != blank -%}
                <a href="{{ large.settings.btn_url }}" class="btn btn-white-sm">{{ large.settings.btn_label }}</a>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endif -%}
      <div class="promo-stack">
        {%- for block in section.blocks -%}
          {%- if block.type == 'small' -%}
            <div class="promo-small" {{ block.shopify_attributes }}>
              <div class="promo-bg" style="background-image:url('{{ block.settings.image | image_url: width: 600 }}')">
                <div class="promo-overlay"></div>
                <div class="promo-text">
                  <h3>{{ block.settings.title }}</h3>
                  {%- if block.settings.link != blank -%}
                    <a href="{{ block.settings.link }}" class="promo-link">{{ block.settings.link_label | default: 'Entdecken' }} &rarr;</a>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Promo Tiles",
  "tag": "section",
  "blocks": [
    {
      "type": "large",
      "name": "Großes Tile",
      "limit": 1,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Bild" },
        { "type": "text", "id": "title", "label": "Titel", "default": "Summer Sale" },
        { "type": "text", "id": "subtitle", "label": "Untertitel", "default": "Bis zu 40% Rabatt" },
        { "type": "text", "id": "btn_label", "label": "Button Text", "default": "Jetzt shoppen" },
        { "type": "url", "id": "btn_url", "label": "Button Link" }
      ]
    },
    {
      "type": "small",
      "name": "Kleines Tile",
      "limit": 2,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Bild" },
        { "type": "text", "id": "title", "label": "Titel", "default": "Kategorie" },
        { "type": "text", "id": "link_label", "label": "Link Text", "default": "Entdecken" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo Tiles",
      "blocks": [
        { "type": "large", "settings": { "title": "Summer Sale", "subtitle": "Bis zu 40% Rabatt" } },
        { "type": "small", "settings": { "title": "Accessories" } },
        { "type": "small", "settings": { "title": "Membership" } }
      ]
    }
  ]
}
{% endschema %}
