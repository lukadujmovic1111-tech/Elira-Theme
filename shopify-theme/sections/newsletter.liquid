<section class="newsletter-section">
  <div class="container">
    <div class="newsletter-wrap reveal">
      {%- if section.settings.eyebrow != blank -%}
        <span class="t-label" style="color:rgba(255,255,255,.5);display:block;margin-bottom:1rem">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading | default: 'Als Erstes informiert sein' }}</h2>
      <p>{{ section.settings.text | default: 'Tritt der Elira Community bei und erhalte exklusiven Zugang zu neuen Kollektionen, Insider-Drops und Community-Events.' }}</p>

      {%- form 'customer', id: 'nl-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="nl-form">
          <input type="email"
                 name="contact[email]"
                 placeholder="Deine E-Mail-Adresse"
                 class="nl-input"
                 required
                 autocomplete="email"
                 aria-label="E-Mail-Adresse">
          <button type="submit" class="nl-btn">{{ section.settings.btn_label | default: 'Anmelden' }}</button>
        </div>
        {%- if form.posted_successfully? -%}
          <p style="color:rgba(255,255,255,.8);margin-top:0.75rem;font-size:0.875rem;">✓ Erfolgreich angemeldet! Willkommen in der Community.</p>
        {%- endif -%}
        {%- if form.errors -%}
          <p style="color:rgba(255,100,100,.9);margin-top:0.75rem;font-size:0.875rem;">{{ form.errors | default_errors }}</p>
        {%- endif -%}
      {%- endform -%}

      <p class="nl-note">Mit der Anmeldung stimmst du unserer <a href="/policies/privacy-policy">Datenschutzerklärung</a> zu. Jederzeit abmeldbar.</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "section-newsletter",
  "settings": [
    { "type": "text",     "id": "eyebrow",   "label": "Eyebrow",     "default": "Stay connected" },
    { "type": "text",     "id": "heading",   "label": "Überschrift", "default": "Als Erstes informiert sein" },
    { "type": "textarea", "id": "text",      "label": "Text",        "default": "Tritt der Elira Community bei und erhalte exklusiven Zugang zu neuen Kollektionen." },
    { "type": "text",     "id": "btn_label", "label": "Button Text", "default": "Anmelden" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
