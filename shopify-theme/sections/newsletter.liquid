<section class="newsletter-section">
  <div class="container">
    <div class="newsletter-wrap">
      <h2>{{ section.settings.heading | default: 'Als Erstes informiert sein' }}</h2>
      <p>{{ section.settings.text | default: 'Tritt der Community bei und erhalte exklusiven Zugang zu neuen Kollektionen.' }}</p>
      {%- form 'customer', id: 'nl-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="nl-form">
          <input type="email" name="contact[email]" placeholder="Deine E-Mail-Adresse" required>
          <button type="submit" class="btn btn-black">{{ section.settings.btn_label | default: 'Anmelden' }}</button>
        </div>
        {%- if form.posted_successfully? -%}
          <p style="color:#4caf50;margin-top:10px;">Du hast dich erfolgreich angemeldet!</p>
        {%- endif -%}
      {%- endform -%}
      <p class="nl-note">Mit der Anmeldung stimmst du unserer <a href="/policies/privacy-policy">Datenschutzerklärung</a> zu.</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Als Erstes informiert sein" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Tritt der Community bei und erhalte exklusiven Zugang zu neuen Kollektionen." },
    { "type": "text", "id": "btn_label", "label": "Button Text", "default": "Anmelden" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
