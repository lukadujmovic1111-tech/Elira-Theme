<section class="hero">
  <div class="hero-slider" id="hero-slider">
    {%- for block in section.blocks -%}
      {%- if block.type == 'slide' -%}
        <div class="hero-slide{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>

          <!-- Background -->
          <div class="hero-slide-bg">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 1920 }}"
                   srcset="{{ block.settings.image | image_url: width: 800 }} 800w,
                           {{ block.settings.image | image_url: width: 1200 }} 1200w,
                           {{ block.settings.image | image_url: width: 1920 }} 1920w"
                   sizes="100vw"
                   alt="{{ block.settings.image.alt | escape }}"
                   loading="{{ forloop.first | ternary: 'eager', 'lazy' }}"
                   fetchpriority="{{ forloop.first | ternary: 'high', 'low' }}"
                   width="1920" height="1080">
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>

          <!-- Overlay -->
          {%- assign pos = block.settings.content_position | default: 'left' -%}
          <div class="hero-overlay{% if pos == 'right' %}--right{% elsif pos == 'center' %}--center{% endif %} hero-overlay"></div>

          <!-- Content -->
          <div class="hero-content hero-content--{{ pos }}">
            {%- if block.settings.eyebrow != blank -%}
              <span class="hero-eyebrow">{{ block.settings.eyebrow }}</span>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h1 class="hero-title">{{ block.settings.heading | newline_to_br }}</h1>
            {%- endif -%}
            {%- if block.settings.subtext != blank -%}
              <p class="hero-sub">{{ block.settings.subtext }}</p>
            {%- endif -%}
            <div class="hero-btns">
              {%- if block.settings.btn1_label != blank -%}
                <a href="{{ block.settings.btn1_url | default: '/collections/all' }}" class="btn btn--light">{{ block.settings.btn1_label }}</a>
              {%- endif -%}
              {%- if block.settings.btn2_label != blank -%}
                <a href="{{ block.settings.btn2_url | default: '/collections/all' }}" class="btn btn--ghost">{{ block.settings.btn2_label }}</a>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}

    <!-- Scroll hint -->
    <div class="hero-scroll-hint" aria-hidden="true">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </div>

  <!-- Slider controls -->
  {%- if section.blocks.size > 1 -%}
    <div class="slider-controls" aria-label="Slider Navigation">
      <button class="slider-btn" id="hero-prev" aria-label="Vorheriger Slide">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <div class="slider-dots" id="hero-dots" role="tablist">
        {%- for block in section.blocks -%}
          {%- if block.type == 'slide' -%}
            <button class="slider-dot{% if forloop.first %} is-active{% endif %}"
                    data-index="{{ forloop.index0 }}"
                    role="tab"
                    aria-label="Slide {{ forloop.index }}"
                    aria-selected="{{ forloop.first | ternary: 'true', 'false' }}">
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <button class="slider-btn" id="hero-next" aria-label="Nächster Slide">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero Slider",
  "tag": "section",
  "class": "section-hero",
  "max_blocks": 5,
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image",            "label": "Hintergrundbild" },
        { "type": "text",         "id": "eyebrow",          "label": "Eyebrow Text",    "default": "Neue Kollektion" },
        { "type": "textarea",     "id": "heading",          "label": "Überschrift",     "default": "Made to Move." },
        { "type": "text",         "id": "subtext",          "label": "Untertext",       "default": "Entdecke unsere neue Kollektion." },
        { "type": "select",       "id": "content_position", "label": "Textposition",
          "options": [
            { "value": "left",   "label": "Links" },
            { "value": "center", "label": "Mitte" },
            { "value": "right",  "label": "Rechts" }
          ], "default": "left" },
        { "type": "text", "id": "btn1_label", "label": "Button 1 Text", "default": "Jetzt shoppen" },
        { "type": "url",  "id": "btn1_url",   "label": "Button 1 Link" },
        { "type": "text", "id": "btn2_label", "label": "Button 2 Text" },
        { "type": "url",  "id": "btn2_url",   "label": "Button 2 Link" }
      ]
    }
  ],
  "presets": [{
    "name": "Hero Slider",
    "blocks": [{ "type": "slide" }, { "type": "slide" }]
  }]
}
{% endschema %}
