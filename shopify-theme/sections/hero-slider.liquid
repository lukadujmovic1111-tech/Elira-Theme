{{ 'elira.css' | asset_url | stylesheet_tag }}

<section class="hero-section">
  <div class="hero-slider" id="hero-slider">
    {%- for block in section.blocks -%}
      {%- if block.type == 'slide' -%}
        <div class="hero-slide{% if forloop.first %} active{% endif %}"
             style="background-image:url('{{ block.settings.image | image_url: width: 1920 }}')"
             {{ block.shopify_attributes }}>
          <div class="slide-overlay{% if block.settings.overlay_side == 'right' %} slide-overlay-right{% endif %}"></div>
          <div class="slide-content pos-{{ block.settings.content_position }}">
            {%- if block.settings.eyebrow != blank -%}
              <span class="eyebrow">{{ block.settings.eyebrow }}</span>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h1>{{ block.settings.heading }}</h1>
            {%- endif -%}
            {%- if block.settings.subtext != blank -%}
              <p>{{ block.settings.subtext }}</p>
            {%- endif -%}
            <div class="slide-btns{% if block.settings.content_position == 'center' %} center{% elsif block.settings.content_position == 'right' %} right{% endif %}">
              {%- if block.settings.btn1_label != blank -%}
                <a href="{{ block.settings.btn1_url }}" class="btn btn-white">{{ block.settings.btn1_label }}</a>
              {%- endif -%}
              {%- if block.settings.btn2_label != blank -%}
                <a href="{{ block.settings.btn2_url }}" class="btn btn-ghost">{{ block.settings.btn2_label }}</a>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="slider-controls">
      <button class="slider-arrow" id="hero-prev" aria-label="Zurück">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <div class="slider-dots" id="hero-dots">
        {%- for block in section.blocks -%}
          {%- if block.type == 'slide' -%}
            <button class="dot{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}"></button>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <button class="slider-arrow" id="hero-next" aria-label="Weiter">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero Slider",
  "tag": "section",
  "class": "hero-slider-section",
  "max_blocks": 5,
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Bild" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow Text", "default": "Neue Kollektion" },
        { "type": "textarea", "id": "heading", "label": "Überschrift", "default": "Made to Move." },
        { "type": "text", "id": "subtext", "label": "Untertext", "default": "Die neue Kollektion ist jetzt da." },
        { "type": "select", "id": "content_position", "label": "Textposition", "options": [{"value":"left","label":"Links"},{"value":"center","label":"Mitte"},{"value":"right","label":"Rechts"}], "default": "left" },
        { "type": "select", "id": "overlay_side", "label": "Overlay-Seite", "options": [{"value":"left","label":"Links"},{"value":"right","label":"Rechts"}], "default": "left" },
        { "type": "text", "id": "btn1_label", "label": "Button 1 Text", "default": "Jetzt shoppen" },
        { "type": "url", "id": "btn1_url", "label": "Button 1 Link" },
        { "type": "text", "id": "btn2_label", "label": "Button 2 Text" },
        { "type": "url", "id": "btn2_url", "label": "Button 2 Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
