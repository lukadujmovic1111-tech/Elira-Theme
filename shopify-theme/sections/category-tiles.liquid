<section class="cat-section">
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.eyebrow != blank -%}
      <div class="sec-head sec-head--center reveal">
        {%- if section.settings.eyebrow != blank -%}
          <span class="sec-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="sec-title">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="cat-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.url | default: block.settings.link }}"
           class="cat-card reveal"
           {{ block.shopify_attributes }}>
          <div class="cat-img-wrap">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 800 }}"
                   srcset="{{ block.settings.image | image_url: width: 400 }} 400w, {{ block.settings.image | image_url: width: 800 }} 800w"
                   sizes="(max-width:768px) 50vw, 33vw"
                   alt="{{ block.settings.title | escape }}"
                   loading="lazy"
                   width="800" height="1067">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="cat-info">
            <span class="cat-name">{{ block.settings.title }}</span>
            <span class="cat-cta">{{ block.settings.cta | default: 'Entdecken' }}</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category Tiles",
  "tag": "section",
  "class": "section-categories",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow",     "default": "Kollektionen" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Shop by Category" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Kategorie",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Bild" },
        { "type": "text", "id": "title", "label": "Titel",       "default": "Kategorie" },
        { "type": "text", "id": "cta",   "label": "Button Text", "default": "Entdecken" },
        { "type": "url",  "id": "url",   "label": "Link" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [{
    "name": "Category Tiles",
    "blocks": [
      { "type": "tile", "settings": { "title": "Yoga & Studio" } },
      { "type": "tile", "settings": { "title": "High Performance" } },
      { "type": "tile", "settings": { "title": "Lifestyle Sets" } }
    ]
  }]
}
{% endschema %}
