<section class="cat-section">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="section-title centered">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="cat-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}" class="cat-card" {{ block.shopify_attributes }}>
          <div class="cat-img-wrap">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="cat-overlay">
            <h3>{{ block.settings.title }}</h3>
            <span class="cat-cta">{{ block.settings.cta | default: 'Shop Now' }}</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category Tiles",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Shop by Category" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Kategorie",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Bild" },
        { "type": "text", "id": "title", "label": "Titel", "default": "Kategorie" },
        { "type": "text", "id": "cta", "label": "Button Text", "default": "Shop Now" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Tiles",
      "blocks": [
        { "type": "tile", "settings": { "title": "Damen" } },
        { "type": "tile", "settings": { "title": "Herren" } },
        { "type": "tile", "settings": { "title": "Accessories" } }
      ]
    }
  ]
}
{% endschema %}
