<section class="values-section">
  <div class="container">
    <div class="values-grid">
      {%- for block in section.blocks -%}
        <div class="value-item" {{ block.shopify_attributes }}>
          <div class="val-icon">
            {%- case block.settings.icon -%}
              {%- when 'shield' -%}
                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {%- when 'chart' -%}
                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
              {%- when 'people' -%}
                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              {%- when 'truck' -%}
                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- else -%}
                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            {%- endcase -%}
          </div>
          <h4>{{ block.settings.title }}</h4>
          <p>{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Values",
  "tag": "section",
  "blocks": [
    {
      "type": "value",
      "name": "Wert",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [{"value":"shield","label":"Schild"},{"value":"chart","label":"Chart"},{"value":"people","label":"Menschen"},{"value":"truck","label":"Lieferung"},{"value":"clock","label":"Uhr"}], "default": "shield" },
        { "type": "text", "id": "title", "label": "Titel", "default": "Qualität" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Beschreibung hier eingeben." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Values",
      "blocks": [
        { "type": "value", "settings": { "icon": "shield", "title": "Nachhaltige Qualität", "text": "Jedes Stück wird mit besonderem Augenmerk auf Umweltverantwortung entwickelt." } },
        { "type": "value", "settings": { "icon": "chart", "title": "Technologische Innovation", "text": "Proprietäre Gewebe für maximale Performance bei jeder Bewegung." } },
        { "type": "value", "settings": { "icon": "people", "title": "Community First", "text": "Wir sind mehr als eine Marke – eine weltweite Gemeinschaft von Bewegten." } },
        { "type": "value", "settings": { "icon": "truck", "title": "Kostenloser Versand", "text": "Gratis Versand ab €100 und kostenlose Rücksendung innerhalb von 30 Tagen." } }
      ]
    }
  ]
}
{% endschema %}
