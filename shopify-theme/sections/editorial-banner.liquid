<section class="editorial-section">
  <div class="editorial-bg" style="background-image:url('{{ section.settings.image | image_url: width: 1920 }}')">
    <div class="editorial-overlay"></div>
    <div class="editorial-content">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.text != blank -%}
        <p>{{ section.settings.text }}</p>
      {%- endif -%}
      {%- if section.settings.btn_label != blank -%}
        <a href="{{ section.settings.btn_url }}" class="btn btn-white">{{ section.settings.btn_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial Banner",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hintergrundbild" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Community" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "The Elira Movement" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Millionen von Menschen. Eine Gemeinschaft." },
    { "type": "text", "id": "btn_label", "label": "Button Text", "default": "Community entdecken" },
    { "type": "url", "id": "btn_url", "label": "Button Link" }
  ],
  "presets": [{ "name": "Editorial Banner" }]
}
{% endschema %}
