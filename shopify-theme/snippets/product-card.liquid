<div class="prod-card">
  <div class="prod-img-wrap">

    <!-- Badge -->
    {%- if product.available == false -%}
      <span class="prod-badge badge--sale">Ausverkauft</span>
    {%- elsif product.compare_at_price > product.price -%}
      {%- assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
      <span class="prod-badge badge--sale">−{{ savings }}%</span>
    {%- elsif product.tags contains 'new' or product.tags contains 'neu' -%}
      <span class="prod-badge badge--new">Neu</span>
    {%- elsif product.tags contains 'bestseller' -%}
      <span class="prod-badge badge--best">Bestseller</span>
    {%- endif -%}

    <!-- Images -->
    <a href="{{ product.url }}" aria-label="{{ product.title | escape }}" tabindex="-1">
      {%- if product.featured_image != blank -%}
        <img src="{{ product.featured_image | image_url: width: 600 }}"
             alt="{{ product.featured_image.alt | default: product.title | escape }}"
             class="img-main"
             loading="lazy"
             width="600"
             height="840">
        {%- if product.images.size > 1 -%}
          <img src="{{ product.images[1] | image_url: width: 600 }}"
               alt="{{ product.title | escape }}"
               class="img-alt"
               loading="lazy"
               width="600"
               height="840">
        {%- endif -%}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg img-main' }}
      {%- endif -%}
    </a>

    <!-- Quick Add -->
    {%- if product.available -%}
      <button class="quick-add"
              data-product-id="{{ product.id }}"
              data-variant-id="{{ product.first_available_variant.id }}"
              aria-label="{{ product.title | escape }} in den Warenkorb">
        Schnell hinzufügen
      </button>
    {%- endif -%}

    <!-- Wishlist -->
    <button class="wish-btn" aria-label="{{ product.title | escape }} zur Wunschliste hinzufügen">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
    </button>
  </div>

  <!-- Info -->
  <div class="prod-info">
    <p class="prod-name">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </p>

    {%- assign color_opt = product.options_by_name['Farbe'] | default: product.options_by_name['Color'] | default: product.options_by_name['Colour'] -%}
    {%- if color_opt and color_opt.values.size > 0 -%}
      <div class="prod-colors" aria-label="Verfügbare Farben">
        {%- for value in color_opt.values limit: 4 -%}
          <span class="color-swatch"
                style="background-color: {{ value | downcase | replace: ' ', '' | replace: '/', '' }};"
                title="{{ value }}"
                aria-label="{{ value }}">
          </span>
        {%- endfor -%}
        {%- if color_opt.values.size > 4 -%}
          <span class="color-more">+{{ color_opt.values.size | minus: 4 }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    <p class="prod-price">
      {%- if product.compare_at_price > product.price -%}
        <span class="price--sale">{{ product.price | money }}</span>
        <span class="price--orig">{{ product.compare_at_price | money }}</span>
      {%- else -%}
        <span>{{ product.price | money }}</span>
      {%- endif -%}
    </p>
  </div>
</div>
