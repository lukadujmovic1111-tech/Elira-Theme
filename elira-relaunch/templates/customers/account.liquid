<div class="container account-wrap">
  <span class="eyebrow">Mein Konto</span>
  <h1>Hallo{% if customer.first_name %}, {{ customer.first_name }}{% endif %}</h1>
  <p style="color: var(--c-muted);"><a href="{{ routes.account_logout_url }}" style="text-decoration: underline;">Abmelden</a></p>

  <div class="account-grid">
    <div>
      <h3 style="font-size:12px; font-weight:600; letter-spacing:.18em; text-transform:uppercase; margin-bottom:16px;">Bestellungen</h3>
      {%- if customer.orders.size > 0 -%}
        <table class="account-table">
          <thead>
            <tr><th>Bestellung</th><th>Datum</th><th>Status</th><th>Summe</th></tr>
          </thead>
          <tbody>
            {%- for order in customer.orders -%}
              <tr>
                <td><a href="{{ order.customer_url }}" style="text-decoration:underline;">{{ order.name }}</a></td>
                <td>{{ order.created_at | date: '%d.%m.%Y' }}</td>
                <td>{{ order.financial_status_label }}</td>
                <td>{{ order.total_price | money }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      {%- else -%}
        <p style="color: var(--c-muted);">Du hast noch keine Bestellungen aufgegeben.</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary btn--sm" style="margin-top: 16px;">Jetzt shoppen</a>
      {%- endif -%}
    </div>

    <aside class="account-side">
      <h3>Standardadresse</h3>
      {%- if customer.default_address -%}
        <p>
          {{ customer.default_address.first_name }} {{ customer.default_address.last_name }}<br>
          {{ customer.default_address.address1 }}<br>
          {%- if customer.default_address.address2 != blank -%}{{ customer.default_address.address2 }}<br>{%- endif -%}
          {{ customer.default_address.zip }} {{ customer.default_address.city }}<br>
          {{ customer.default_address.country_name }}
        </p>
      {%- else -%}
        <p>Noch keine Adresse hinterlegt.</p>
      {%- endif -%}
      <p style="margin-top: 14px;"><a href="{{ routes.account_addresses_url }}">Adressen verwalten ({{ customer.addresses_count }})</a></p>
    </aside>
  </div>
</div>
