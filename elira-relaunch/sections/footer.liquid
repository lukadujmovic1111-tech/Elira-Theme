<footer class="ftr">
  <div class="container">
    <div class="ftr__grid">
      <div class="ftr__brand">
        <a href="{{ routes.root_url }}" class="ftr__wordmark">{{ shop.name }}</a>
        <p class="ftr__tagline">{{ settings.brand_tagline | default: 'Soft performance — designed to move with you.' }}</p>
        <div class="ftr__social">
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2.5" y="2.5" width="19" height="19" rx="5"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.4" cy="6.6" r="1" fill="currentColor" stroke="none"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_tiktok != blank -%}
            <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_pinterest != blank -%}
            <a href="{{ settings.social_pinterest }}" target="_blank" rel="noopener" aria-label="Pinterest">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9.5"/><path d="M9.5 21l3-9.5M8 13.5c-.6-.7-1-1.7-1-2.8A5 5 0 0 1 12 6c2.8 0 5 1.8 5 4.4 0 2.7-1.6 4.6-3.8 4.6-1.1 0-2-.5-2.3-1.3"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_facebook != blank -%}
            <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- assign rendered_cols = 0 -%}
      {%- for i in (1..3) -%}
        {%- assign menu_key = 'menu_' | append: i -%}
        {%- assign title_key = 'title_' | append: i -%}
        {%- assign menu = linklists[section.settings[menu_key]] -%}
        {%- if menu.links.size > 0 -%}
          {%- assign rendered_cols = rendered_cols | plus: 1 -%}
          <nav class="ftr__col" aria-label="{{ section.settings[title_key] | default: menu.title }}">
            <h4>{{ section.settings[title_key] | default: menu.title }}</h4>
            <ul>
              {%- for link in menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </nav>
        {%- endif -%}
      {%- endfor -%}

      {%- if rendered_cols == 0 -%}
        <nav class="ftr__col" aria-label="Shop">
          <h4>Shop</h4>
          <ul>
            <li><a href="/collections/new">New In</a></li>
            <li><a href="/collections/bestseller">Bestseller</a></li>
            <li><a href="{{ routes.collections_url }}">Kollektionen</a></li>
            <li><a href="/collections/sale">Sale</a></li>
          </ul>
        </nav>
        <nav class="ftr__col" aria-label="Hilfe und Informationen">
          <h4>Hilfe &amp; Info</h4>
          <ul>
            <li><a href="{{ routes.account_url }}">Mein Konto</a></li>
            <li><a href="/pages/versand-rueckgabe">Versand &amp; Rückgabe</a></li>
            <li><a href="/pages/groessenguide">Größenguide</a></li>
            <li><a href="/pages/faq">FAQ</a></li>
            <li><a href="/pages/kontakt">Kontakt</a></li>
          </ul>
        </nav>
        <nav class="ftr__col" aria-label="Über Elira">
          <h4>Elira World</h4>
          <ul>
            <li><a href="/pages/about">Unsere Geschichte</a></li>
            <li><a href="/pages/community">Community</a></li>
            <li><a href="/pages/nachhaltigkeit">Nachhaltigkeit</a></li>
            <li><a href="/blogs/journal">Journal</a></li>
          </ul>
        </nav>
      {%- endif -%}
    </div>

    <div class="ftr__bottom">
      <span class="ftr__copy">&copy; {{ 'now' | date: '%Y' }} — {{ shop.name }}. Alle Rechte vorbehalten.</span>
      <div class="pay-chips" aria-label="Zahlungsarten">
        <span class="pay-chip">VISA</span>
        <span class="pay-chip">MASTERCARD</span>
        <span class="pay-chip">PAYPAL</span>
        <span class="pay-chip">KLARNA</span>
        <span class="pay-chip">APPLE PAY</span>
      </div>
      <div class="ftr__legal">
        <a href="/policies/privacy-policy">Datenschutz</a>
        <a href="/policies/terms-of-service">AGB</a>
        <a href="/policies/refund-policy">Widerruf</a>
        <a href="/policies/legal-notice">Impressum</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "header", "content": "Spalte 1" },
    { "type": "text", "id": "title_1", "label": "Titel", "default": "Shop" },
    { "type": "link_list", "id": "menu_1", "label": "Menü" },
    { "type": "header", "content": "Spalte 2" },
    { "type": "text", "id": "title_2", "label": "Titel", "default": "Hilfe & Info" },
    { "type": "link_list", "id": "menu_2", "label": "Menü" },
    { "type": "header", "content": "Spalte 3" },
    { "type": "text", "id": "title_3", "label": "Titel", "default": "Elira World" },
    { "type": "link_list", "id": "menu_3", "label": "Menü" }
  ]
}
{% endschema %}
