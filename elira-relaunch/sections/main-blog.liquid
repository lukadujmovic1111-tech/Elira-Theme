{%- paginate blog.articles by 9 -%}
<div class="container">
  <div class="page-hero">
    <span class="eyebrow">Journal</span>
    <h1>{{ blog.title }}</h1>
  </div>
  <div class="blog-grid">
    {%- for article in blog.articles -%}
      <article class="bcard reveal">
        <a href="{{ article.url }}">
          <div class="bcard__media">
            {%- if article.image -%}
              <img src="{{ article.image | image_url: width: 900 }}" alt="{{ article.title | escape }}" loading="lazy">
            {%- endif -%}
          </div>
          <span class="bcard__date">{{ article.published_at | date: '%d. %B %Y' }}</span>
          <h2 class="bcard__title">{{ article.title }}</h2>
          <p class="bcard__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
        </a>
      </article>
    {%- endfor -%}
  </div>
  {%- if paginate.pages > 1 -%}
    <nav class="pagination" aria-label="Seiten">
      {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">←</a>{%- endif -%}
      {%- for part in paginate.parts -%}
        {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>
        {%- elsif part.title == paginate.current_page -%}<span class="current">{{ part.title }}</span>
        {%- else -%}<span>{{ part.title }}</span>{%- endif -%}
      {%- endfor -%}
      {%- if paginate.next -%}<a href="{{ paginate.next.url }}">→</a>{%- endif -%}
    </nav>
  {%- endif -%}
</div>
{%- endpaginate -%}

{% schema %}
{
  "name": "Blog",
  "settings": []
}
{% endschema %}
