<section class="shopby-section">
  <div class="container">
    <div class="section-head reveal">
      <div>
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2 class="section-title">{{ section.settings.heading | default: 'Shop by Activity' }}</h2>
      </div>
      {%- if section.settings.link_label != blank -%}
        <a href="{{ section.settings.link | default: routes.collections_url }}" class="section-link">{{ section.settings.link_label }}</a>
      {%- endif -%}
    </div>

    <div class="shopby__row reveal">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- assign coll = block.settings.collection -%}
          <a href="{{ coll.url | default: block.settings.link | default: routes.all_products_collection_url }}" class="shopby__card" {{ block.shopify_attributes }}>
            <div class="shopby__img">
              {%- if block.settings.image -%}
                <img src="{{ block.settings.image | image_url: width: 640 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
              {%- elsif coll.image -%}
                <img src="{{ coll.image | image_url: width: 640 }}" alt="{{ coll.title | escape }}" loading="lazy">
              {%- else -%}
                <img src="https://images.unsplash.com/photo-{{ block.settings.fallback_id | default: '1518611012118-696072aa579a' }}?auto=format&fit=crop&w=640&h=854&q=80" alt="" loading="lazy">
              {%- endif -%}
            </div>
            <span class="shopby__name">
              {{ block.settings.title | default: coll.title }}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- assign demo = 'Yoga;1518611012118-696072aa579a|Pilates;1534258936459-347d08ab1be8|Running;1538805060514-97d9cc17730c|Studio;1571019613454-1cb2f99b2d8b|Vacation;1556906781-9a412961a28c|Everyday;1583454155184-870a1f63aebc' | split: '|' -%}
        {%- for item in demo -%}
          {%- assign parts = item | split: ';' -%}
          <a href="{{ routes.all_products_collection_url }}" class="shopby__card">
            <div class="shopby__img">
              <img src="https://images.unsplash.com/photo-{{ parts[1] }}?auto=format&fit=crop&w=640&h=854&q=80" alt="" loading="lazy">
            </div>
            <span class="shopby__name">
              {{ parts[0] }}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop-by-Kacheln",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Shop by Activity" },
    { "type": "text", "id": "link_label", "label": "Link-Text" },
    { "type": "url", "id": "link", "label": "Link" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Kachel",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Kollektion" },
        { "type": "image_picker", "id": "image", "label": "Bild" },
        { "type": "text", "id": "fallback_id", "label": "Unsplash-Fallback-ID" },
        { "type": "text", "id": "title", "label": "Titel" },
        { "type": "url", "id": "link", "label": "Link (falls keine Kollektion)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop-by-Kacheln",
      "blocks": [{ "type": "tile" }, { "type": "tile" }, { "type": "tile" }, { "type": "tile" }, { "type": "tile" }, { "type": "tile" }]
    }
  ]
}
{% endschema %}
