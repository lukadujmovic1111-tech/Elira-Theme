<section class="edit3-section">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <div class="section-head reveal">
        <div>
          {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
          <h2 class="section-title">{{ section.settings.heading }}</h2>
        </div>
      </div>
    {%- endif -%}

    <div class="edit3">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <a href="{{ block.settings.link | default: '#' }}" class="edit3__card reveal" {{ block.shopify_attributes }}>
            <div class="edit3__media">
              {%- if block.settings.image -%}
                <img src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
              {%- else -%}
                <img src="https://images.unsplash.com/photo-{{ block.settings.fallback_id | default: '1547592180-85f173990554' }}?auto=format&fit=crop&w=900&h=1125&q=80" alt="" loading="lazy">
              {%- endif -%}
            </div>
            {%- if block.settings.label != blank -%}<span class="edit3__label">{{ block.settings.label }}</span>{%- endif -%}
            <h3 class="edit3__title">{{ block.settings.title }}</h3>
            {%- if block.settings.text != blank -%}<p class="edit3__text">{{ block.settings.text }}</p>{%- endif -%}
            <span class="edit3__link">{{ block.settings.link_label | default: 'Mehr entdecken' }}</span>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- assign demo = 'Journal;Studio Diaries;Einblicke aus dem Elira Studio — Routinen, Rituale, Looks.;1547592180-85f173990554|Styling;Summer Looks;Unsere Lieblings-Kombinationen für warme Tage.;1556906781-9a412961a28c|Event;Berlin Pop-Up;Save the Date — wir kommen nach Berlin-Mitte.;1536766820879-059fec98ec0a' | split: '|' -%}
        {%- for item in demo -%}
          {%- assign parts = item | split: ';' -%}
          <a href="#" class="edit3__card reveal">
            <div class="edit3__media">
              <img src="https://images.unsplash.com/photo-{{ parts[3] }}?auto=format&fit=crop&w=900&h=1125&q=80" alt="" loading="lazy">
            </div>
            <span class="edit3__label">{{ parts[0] }}</span>
            <h3 class="edit3__title">{{ parts[1] }}</h3>
            <p class="edit3__text">{{ parts[2] }}</p>
            <span class="edit3__link">Mehr entdecken</span>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial-Trio",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Elira World" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Mehr als Activewear" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Karte",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Bild" },
        { "type": "text", "id": "fallback_id", "label": "Unsplash-Fallback-ID" },
        { "type": "text", "id": "label", "label": "Label", "default": "Journal" },
        { "type": "text", "id": "title", "label": "Titel", "default": "Studio Diaries" },
        { "type": "text", "id": "text", "label": "Text" },
        { "type": "text", "id": "link_label", "label": "Link-Text", "default": "Mehr entdecken" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial-Trio",
      "blocks": [{ "type": "card" }, { "type": "card" }, { "type": "card" }]
    }
  ]
}
{% endschema %}
