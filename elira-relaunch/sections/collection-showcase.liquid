<section class="showcase-wrap">
  <div class="container">
    <div class="showcase">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- assign coll = block.settings.collection -%}
          <a href="{{ coll.url | default: block.settings.link | default: routes.all_products_collection_url }}" class="showcase__item reveal" {{ block.shopify_attributes }}>
            {%- if block.settings.image -%}
              <img class="showcase__img" src="{{ block.settings.image | image_url: width: 2200 }}"
                srcset="{{ block.settings.image | image_url: width: 1100 }} 1100w, {{ block.settings.image | image_url: width: 2200 }} 2200w"
                sizes="100vw" alt="{{ block.settings.title | escape }}" loading="lazy">
            {%- elsif coll.image -%}
              <img class="showcase__img" src="{{ coll.image | image_url: width: 2200 }}" alt="{{ coll.title | escape }}" loading="lazy">
            {%- else -%}
              <img class="showcase__img" src="https://images.unsplash.com/photo-{{ block.settings.fallback_id | default: '1538805060514-97d9cc17730c' }}?auto=format&fit=crop&w=2200&q=80" alt="" loading="lazy">
            {%- endif -%}
            <div class="showcase__veil"></div>
            <div class="showcase__content">
              <div>
                {%- if block.settings.label != blank -%}<span class="eyebrow">{{ block.settings.label }}</span>{%- endif -%}
                <h3 class="showcase__name">{{ block.settings.title | default: coll.title }}</h3>
              </div>
              <span class="btn btn--ghost-light showcase__cta">{{ block.settings.cta | default: 'Explore' }}</span>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        <a href="{{ routes.all_products_collection_url }}" class="showcase__item reveal">
          <img class="showcase__img" src="https://images.unsplash.com/photo-1538805060514-97d9cc17730c?auto=format&fit=crop&w=2200&q=80" alt="" loading="lazy">
          <div class="showcase__veil"></div>
          <div class="showcase__content">
            <div><span class="eyebrow">Kollektion</span><h3 class="showcase__name">Aura</h3></div>
            <span class="btn btn--ghost-light showcase__cta">Explore</span>
          </div>
        </a>
        <a href="{{ routes.all_products_collection_url }}" class="showcase__item reveal">
          <img class="showcase__img" src="https://images.unsplash.com/photo-1588392382834-a891154bca4d?auto=format&fit=crop&w=2200&q=80" alt="" loading="lazy">
          <div class="showcase__veil"></div>
          <div class="showcase__content">
            <div><span class="eyebrow">Kollektion</span><h3 class="showcase__name">Drift</h3></div>
            <span class="btn btn--ghost-light showcase__cta">Explore</span>
          </div>
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kollektions-Showcase",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Kollektion" },
        { "type": "image_picker", "id": "image", "label": "Bild (überschreibt Kollektionsbild)" },
        { "type": "text", "id": "fallback_id", "label": "Unsplash-Fallback-ID" },
        { "type": "text", "id": "label", "label": "Label", "default": "Kollektion" },
        { "type": "text", "id": "title", "label": "Titel" },
        { "type": "text", "id": "cta", "label": "Button-Text", "default": "Explore" },
        { "type": "url", "id": "link", "label": "Link (falls keine Kollektion)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kollektions-Showcase",
      "blocks": [{ "type": "banner" }, { "type": "banner" }]
    }
  ]
}
{% endschema %}
