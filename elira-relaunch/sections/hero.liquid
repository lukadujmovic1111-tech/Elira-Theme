<section class="hero" role="region" aria-label="Hero">
  {%- assign slide_count = section.blocks.size -%}

  {%- if slide_count > 0 -%}
    {%- for block in section.blocks -%}
      <div class="hero__slide{% if forloop.first %} active{% endif %}" {{ block.shopify_attributes }}>
        {%- if block.settings.video_url != blank -%}
          <video class="hero__video" autoplay muted loop playsinline preload="metadata"
            {% if block.settings.image %}poster="{{ block.settings.image | image_url: width: 1800 }}"{% endif %}>
            <source src="{{ block.settings.video_url }}" type="video/mp4">
          </video>
        {%- elsif block.settings.image -%}
          <img class="hero__img" src="{{ block.settings.image | image_url: width: 2400 }}"
            srcset="{{ block.settings.image | image_url: width: 1100 }} 1100w, {{ block.settings.image | image_url: width: 1800 }} 1800w, {{ block.settings.image | image_url: width: 2400 }} 2400w"
            sizes="100vw"
            alt="{{ block.settings.title | escape }}"
            {% unless forloop.first %}loading="lazy"{% endunless %}>
        {%- else -%}
          <img class="hero__img" src="https://images.unsplash.com/photo-{{ block.settings.fallback_id | default: '1518611012118-696072aa579a' }}?auto=format&fit=crop&w=2200&q=80" alt="" {% unless forloop.first %}loading="lazy"{% endunless %}>
        {%- endif -%}
        <div class="hero__veil"></div>

        <div class="hero__content{% if block.settings.position == 'bottom' %} hero__content--bottom{% endif %}">
          {%- if block.settings.kicker != blank -%}
            <h2 class="hero__kicker">{{ block.settings.kicker }}</h2>
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <p class="hero__title">{{ block.settings.title }}</p>
          {%- endif -%}
          {%- if block.settings.subtext != blank -%}
            <p class="hero__sub">{{ block.settings.subtext }}</p>
          {%- endif -%}
          {%- if block.settings.btn_label != blank -%}
            <div class="hero__ctas">
              <a href="{{ block.settings.btn_link | default: routes.all_products_collection_url }}" class="btn btn--light">{{ block.settings.btn_label }}</a>
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}

    {%- if slide_count > 1 -%}
      <div class="hero__nav">
        <span class="hero__count">01 / 0{{ slide_count }}</span>
        <div class="hero__dots">
          {%- for block in section.blocks -%}
            <button class="hero__dot{% if forloop.first %} active{% endif %}" aria-label="Slide {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

  {%- else -%}
    <div class="hero__slide active">
      <img class="hero__img" src="https://images.unsplash.com/photo-1518611012118-696072aa579a?auto=format&fit=crop&w=2200&q=80" alt="">
      <div class="hero__veil"></div>
      <div class="hero__content">
        <h2 class="hero__kicker">Now Live</h2>
        <p class="hero__title">Soft Sculpt</p>
        <div class="hero__ctas">
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--light">Buy now</a>
        </div>
      </div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Bild" },
        { "type": "text", "id": "video_url", "label": "Video-URL (MP4, optional)", "info": "Direktlink zu einer MP4-Datei — läuft stumm in Schleife (wie bei Exercere)." },
        { "type": "text", "id": "fallback_id", "label": "Unsplash-Fallback-ID", "info": "Nur für die Vorschau ohne eigenes Bild." },
        { "type": "text", "id": "kicker", "label": "Kleine Zeile", "default": "Now Live" },
        { "type": "text", "id": "title", "label": "Titel", "default": "Soft Sculpt" },
        { "type": "text", "id": "subtext", "label": "Untertitel (optional)" },
        {
          "type": "select",
          "id": "position",
          "label": "Position",
          "options": [
            { "value": "center", "label": "Mittig" },
            { "value": "bottom", "label": "Unten" }
          ],
          "default": "center"
        },
        { "type": "text", "id": "btn_label", "label": "Button-Text", "default": "Buy now" },
        { "type": "url", "id": "btn_link", "label": "Button-Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [{ "type": "slide" }]
    }
  ]
}
{% endschema %}
