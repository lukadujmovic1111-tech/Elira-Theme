<section class="fc-section" style="padding-top: 0;">
  <div class="container">
    <div class="carousel" data-carousel>
      <div class="section-head">
        <h2 class="section-title">{{ section.settings.heading | default: 'Das könnte dir gefallen' }}</h2>
        <div class="head-arrows">
          <button class="car-arrow" data-car-prev aria-label="Zurück">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 6l-6 6 6 6"/></svg>
          </button>
          <button class="car-arrow" data-car-next aria-label="Weiter">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 6l6 6-6 6"/></svg>
          </button>
        </div>
      </div>

      <div class="carousel__track">
        {%- if recommendations.performed and recommendations.products_count > 0 -%}
          {%- for rec in recommendations.products -%}
            <div class="carousel__item">{% render 'product-card', card_product: rec %}</div>
          {%- endfor -%}
        {%- else -%}
          {%- assign source = collections.all -%}
          {%- if collection and collection.products.size > 1 -%}
            {%- assign source = collection -%}
          {%- endif -%}
          {%- for rec in source.products limit: 8 -%}
            {%- unless rec.id == product.id -%}
              <div class="carousel__item">{% render 'product-card', card_product: rec %}</div>
            {%- endunless -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Produkt-Empfehlungen",
  "settings": [
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Das könnte dir gefallen" }
  ]
}
{% endschema %}
