{%- comment -%}
  Produktkarte | Nutzung: render 'product-card', card_product: product
{%- endcomment -%}
{%- liquid
  assign img1 = card_product.featured_media.preview_image
  assign img2 = blank
  if card_product.media.size > 1
    assign img2 = card_product.media[1].preview_image
  endif

  assign on_sale = false
  if card_product.compare_at_price > card_product.price
    assign on_sale = true
  endif

  assign is_new = false
  if card_product.tags contains 'Neu' or card_product.tags contains 'New' or card_product.tags contains 'new'
    assign is_new = true
  endif

  assign color_option = blank
  for option in card_product.options_with_values
    assign oname = option.name | downcase
    if oname == 'farbe' or oname == 'color' or oname == 'colour'
      assign color_option = option
    endif
  endfor
-%}

<article class="pcard">
  <div class="pcard__media">
    {%- if card_product.available == false -%}
      <span class="pcard__badge badge--soldout">Ausverkauft</span>
    {%- elsif on_sale -%}
      <span class="pcard__badge badge--sale">Sale</span>
    {%- elsif is_new -%}
      <span class="pcard__badge badge--new">Neu</span>
    {%- endif -%}

    <a href="{{ card_product.url }}" aria-label="{{ card_product.title | escape }}">
      {%- if img1 -%}
        <img
          class="pcard__img {% if img2 %}pcard__img--main{% else %}pcard__img--solo{% endif %}"
          src="{{ img1 | image_url: width: 720 }}"
          srcset="{{ img1 | image_url: width: 480 }} 480w, {{ img1 | image_url: width: 720 }} 720w, {{ img1 | image_url: width: 1080 }} 1080w"
          sizes="(max-width: 640px) 50vw, (max-width: 1120px) 33vw, 25vw"
          alt="{{ img1.alt | default: card_product.title | escape }}"
          loading="lazy" width="{{ img1.width }}" height="{{ img1.height }}">
        {%- if img2 -%}
          <img class="pcard__img pcard__img--alt" src="{{ img2 | image_url: width: 720 }}" alt="" loading="lazy" width="{{ img2.width }}" height="{{ img2.height }}">
        {%- endif -%}
      {%- else -%}
        {{ 'product-apparel-1' | placeholder_svg_tag: 'pcard__img pcard__img--solo' }}
      {%- endif -%}
    </a>

    {%- if card_product.available -%}
      <div class="pcard__quick">
        {%- if card_product.has_only_default_variant -%}
          <button class="qa-single" type="button" data-add-variant="{{ card_product.first_available_variant.id }}">
            In den Warenkorb
          </button>
        {%- elsif card_product.options.size == 1 and card_product.variants.size <= 8 -%}
          <span class="qa-label">Schnell hinzufügen — {{ card_product.options.first }}</span>
          <div class="qa-pills">
            {%- for variant in card_product.variants -%}
              <button class="qa-pill" type="button"
                {% if variant.available %}data-add-variant="{{ variant.id }}"{% else %}disabled{% endif %}>
                {{- variant.title -}}
              </button>
            {%- endfor -%}
          </div>
        {%- else -%}
          <a class="qa-single" style="display:block;text-align:center;" href="{{ card_product.url }}">Optionen wählen</a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  <div class="pcard__info">
    <h3 class="pcard__name"><a href="{{ card_product.url }}">{{ card_product.title }}</a></h3>
    {%- if color_option != blank -%}
      <div class="pcard__swatches" aria-label="Verfügbare Farben">
        {%- for value in color_option.values limit: 4 -%}
          <span class="swatch" style="{% render 'color-swatch-style', value: value %}" title="{{ value | escape }}"></span>
        {%- endfor -%}
        {%- if color_option.values.size > 4 -%}
          <span class="swatch-more">+{{ color_option.values.size | minus: 4 }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}
    {% render 'price', target: card_product %}
  </div>
</article>
