<section class="section error-page">
  <div class="container container--narrow">
    <div class="error-page__inner">
      <p class="eyebrow">404</p>
      <h1 class="section-title section-title--lg">{{ '404.title' | t }}</h1>
      <p class="section-sub">{{ '404.text' | t }}</p>
      <div class="error-page__actions">
        <a href="{{ routes.root_url }}" class="btn btn--primary">{{ '404.back_home' | t }}</a>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--secondary">{{ '404.shop_all' | t }}</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "404",
  "settings": []
}
{% endschema %}
