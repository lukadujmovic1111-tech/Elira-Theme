<section class="section split-banner{% if section.settings.background == 'bone' %} section--bone{% endif %}">
  <div class="container container--wide">
    <div class="split-banner__grid{% if section.settings.image_position == 'right' %} is-flipped{% endif %}">
      <div class="split-banner__media" data-reveal>
        {%- if section.settings.image != blank -%}
          {{ section.settings.image
            | image_url: width: 1400
            | image_tag:
              widths: '600, 900, 1100, 1400',
              sizes: '(min-width: 990px) 50vw, 100vw',
              loading: 'lazy' }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      <div class="split-banner__content" data-reveal>
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="section-title section-title--lg">{{ section.settings.heading }}</h2>
        {%- if section.settings.text != blank -%}
          <div class="split-banner__text rte">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <ul class="split-banner__features">
            {%- for block in section.blocks -%}
              <li {{ block.shopify_attributes }}>
                {% render 'icon', name: 'check', size: 16 %}
                {{ block.settings.text }}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="btn btn--primary">{{ section.settings.button_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bild + Text",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild",
      "info": "Empfohlen: 1200 × 1400 px"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Bildposition (Desktop)",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "background",
      "label": "Hintergrund",
      "options": [
        { "value": "white", "label": "Weiß" },
        { "value": "bone", "label": "Bone (Soft)" }
      ],
      "default": "white"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Studio Essentials"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Vom ersten Sonnengruß bis zum letzten Atemzug"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Unsere Studio Collection begleitet dich durch jede Praxis: Vier-Wege-Stretch, der jede Asana mitmacht, und Schnitte, die deine Silhouette betonen statt einengen.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button-Text",
      "default": "Studio Collection shoppen"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button-Link"
    }
  ],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "feature",
      "name": "Feature-Punkt",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Vier-Wege-Stretch mit perfektem Rückstellvermögen"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bild + Text",
      "blocks": [
        { "type": "feature", "settings": { "text": "Vier-Wege-Stretch mit perfektem Rückstellvermögen" } },
        { "type": "feature", "settings": { "text": "High-Rise-Bund, der nicht rutscht und nicht einschneidet" } },
        { "type": "feature", "settings": { "text": "Feuchtigkeitsableitend & schnelltrocknend" } }
      ]
    }
  ]
}
{% endschema %}
