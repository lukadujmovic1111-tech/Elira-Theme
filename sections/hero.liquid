{%- liquid
  assign height_class = 'hero--large'
  if section.settings.height == 'full'
    assign height_class = 'hero--full'
  elsif section.settings.height == 'medium'
    assign height_class = 'hero--medium'
  endif
-%}

<section class="hero {{ height_class }} hero--text-{{ section.settings.text_position }}">
  <div class="hero__media">
    {%- if section.settings.image != blank -%}
      <picture>
        {%- if section.settings.image_mobile != blank -%}
          <source media="(max-width: 749px)" srcset="{{ section.settings.image_mobile | image_url: width: 750 }} 750w, {{ section.settings.image_mobile | image_url: width: 1100 }} 1100w" sizes="100vw">
        {%- endif -%}
        {{ section.settings.image
          | image_url: width: 2400
          | image_tag:
            widths: '750, 1100, 1500, 1900, 2400',
            sizes: '100vw',
            loading: 'eager',
            fetchpriority: 'high',
            class: 'hero__img' }}
      </picture>
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'hero__img placeholder-svg' }}
    {%- endif -%}
    <div class="hero__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}"></div>
  </div>

  <div class="hero__content container container--wide">
    <div class="hero__box" data-reveal>
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow eyebrow--light">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="hero__heading">{{ section.settings.heading | newline_to_br }}</h1>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="hero__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.button_label != blank or section.settings.button_label_2 != blank -%}
        <div class="hero__actions">
          {%- if section.settings.button_label != blank -%}
            <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="btn btn--light">{{ section.settings.button_label }}</a>
          {%- endif -%}
          {%- if section.settings.button_label_2 != blank -%}
            <a href="{{ section.settings.button_link_2 | default: routes.all_products_collection_url }}" class="btn btn--ghost-light">{{ section.settings.button_label_2 }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild (Desktop)",
      "info": "Empfohlen: 2400 × 1350 px, Lifestyle-Motiv mit ruhiger Fläche für Text."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Bild (Mobil)",
      "info": "Empfohlen: 1100 × 1600 px (Hochformat)."
    },
    {
      "type": "select",
      "id": "height",
      "label": "Höhe",
      "options": [
        { "value": "medium", "label": "Mittel" },
        { "value": "large", "label": "Groß" },
        { "value": "full", "label": "Vollbild" }
      ],
      "default": "full"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Textposition",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay-Stärke",
      "min": 0,
      "max": 70,
      "step": 5,
      "unit": "%",
      "default": 25
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Neu: Die Studio Collection"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Überschrift",
      "default": "Bewegung, die sich\nwie du anfühlt."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Unterzeile",
      "default": "Buttery-soft Activewear für Yoga, Pilates und alles dazwischen."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button 1 — Text",
      "default": "Neuheiten shoppen"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button 1 — Link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button 2 — Text",
      "default": "Bestseller entdecken"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Button 2 — Link"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
