{%- if section.blocks.size > 0 -%}
  <div class="announcement-bar" data-announcement-bar role="region" aria-label="{{ 'general.accessibility.announcement' | t }}">
    <div class="announcement-bar__track">
      {%- for block in section.blocks -%}
        <p class="announcement-bar__item{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}">{{ block.settings.text }}</a>
          {%- else -%}
            {{ block.settings.text }}
          {%- endif -%}
        </p>
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement-Bar",
  "class": "section-announcement",
  "max_blocks": 3,
  "blocks": [
    {
      "type": "message",
      "name": "Nachricht",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Kostenloser Versand ab 100 € — kostenlose Rücksendung"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement-Bar",
      "blocks": [
        { "type": "message", "settings": { "text": "Kostenloser Versand ab 100 € — kostenlose Rücksendung" } },
        { "type": "message", "settings": { "text": "Neu: Die Studio Collection ist da" } },
        { "type": "message", "settings": { "text": "30 Tage Probetragen auf alle Leggings" } }
      ]
    }
  ]
}
{% endschema %}
