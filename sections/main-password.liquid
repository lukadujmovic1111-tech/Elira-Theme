<section class="password-page">
  <div class="password-page__inner">
    <p class="password-page__logo">{{ shop.name }}</p>
    <h1 class="section-title">{{ 'general.password.coming_soon' | t }}</h1>
    <p class="section-sub">{{ 'general.password.text' | t }}</p>

    {%- form 'storefront_password', class: 'password-form' -%}
      {%- if form.errors -%}
        <p class="form-error">{{ 'general.password.error' | t }}</p>
      {%- endif -%}
      <div class="newsletter-form__row">
        <input
          type="password"
          name="password"
          class="newsletter-form__input"
          placeholder="{{ 'general.password.placeholder' | t }}"
          aria-label="{{ 'general.password.placeholder' | t }}"
          required>
        <button type="submit" class="btn btn--primary">{{ 'general.password.submit' | t }}</button>
      </div>
    {%- endform -%}

    <p class="password-page__admin">{{ 'general.password.admin_hint' | t }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Passwortseite",
  "settings": []
}
{% endschema %}
