{%- liquid
  assign threshold = settings.free_shipping_threshold | default: 0 | times: 100
  assign remaining = threshold | minus: cart.total_price
  if threshold > 0
    assign progress = cart.total_price | times: 100.0 | divided_by: threshold | at_most: 100
  endif
-%}
<div class="cart-drawer-wrap" data-cart-drawer aria-hidden="true">
  <div class="drawer-overlay" data-cart-close></div>

  <aside class="cart-drawer" role="dialog" aria-modal="true" tabindex="-1" aria-label="{{ 'cart.general.title' | t }}">
    <div class="cart-drawer__head">
      <h2 class="cart-drawer__title">
        {{ 'cart.general.title' | t }}
        <span class="cart-drawer__count">({{ cart.item_count }})</span>
      </h2>
      <button type="button" class="header-action" data-cart-close aria-label="{{ 'general.accessibility.close' | t }}">
        {% render 'icon', name: 'close', size: 22 %}
      </button>
    </div>

    {%- if cart.item_count == 0 -%}
      <div class="cart-drawer__empty">
        {% render 'icon', name: 'bag', size: 44, stroke_width: 1 %}
        <p class="cart-drawer__empty-title">{{ 'cart.general.empty' | t }}</p>
        <p class="cart-drawer__empty-text">{{ 'cart.general.empty_hint' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">{{ 'cart.general.continue_shopping' | t }}</a>
      </div>
    {%- else -%}

      {%- if threshold > 0 -%}
        <div class="shipping-bar" data-shipping-bar>
          {%- if remaining > 0 -%}
            {%- assign remaining_money = remaining | money -%}
            <p class="shipping-bar__label">{{ 'cart.shipping_bar.remaining_html' | t: amount: remaining_money }}</p>
          {%- else -%}
            <p class="shipping-bar__label shipping-bar__label--unlocked">{% render 'icon', name: 'truck', size: 16 %} {{ 'cart.shipping_bar.unlocked' | t }}</p>
          {%- endif -%}
          <div class="shipping-bar__track">
            <div class="shipping-bar__fill{% if remaining <= 0 %} is-complete{% endif %}" style="width: {{ progress }}%"></div>
          </div>
        </div>
      {%- endif -%}

      <div class="cart-drawer__items">
        {%- for item in cart.items -%}
          <div class="cart-item" data-line-item="{{ item.key }}">
            <a href="{{ item.url }}" class="cart-item__media">
              {%- if item.image -%}
                {{ item.image | image_url: width: 240 | image_tag: widths: '120, 240', sizes: '88px', loading: 'lazy', alt: item.title }}
              {%- endif -%}
            </a>
            <div class="cart-item__info">
              <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
              {%- unless item.product.has_only_default_variant -%}
                <p class="cart-item__variant">
                  {%- for option in item.options_with_values -%}
                    {{ option.value }}{% unless forloop.last %} / {% endunless %}
                  {%- endfor -%}
                </p>
              {%- endunless -%}

              <div class="cart-item__row">
                <div class="qty-stepper" data-qty-stepper>
                  <button type="button" class="qty-stepper__btn" data-cart-qty data-line-key="{{ item.key }}" data-target-qty="{{ item.quantity | minus: 1 }}" aria-label="{{ 'cart.general.decrease' | t }}">
                    {% render 'icon', name: 'minus', size: 13 %}
                  </button>
                  <span class="qty-stepper__value">{{ item.quantity }}</span>
                  <button type="button" class="qty-stepper__btn" data-cart-qty data-line-key="{{ item.key }}" data-target-qty="{{ item.quantity | plus: 1 }}" aria-label="{{ 'cart.general.increase' | t }}">
                    {% render 'icon', name: 'plus', size: 13 %}
                  </button>
                </div>
                <div class="cart-item__price">
                  {%- if item.original_line_price != item.final_line_price -%}
                    <s>{{ item.original_line_price | money }}</s>
                  {%- endif -%}
                  <span>{{ item.final_line_price | money }}</span>
                </div>
              </div>
            </div>
            <button type="button" class="cart-item__remove" data-cart-qty data-line-key="{{ item.key }}" data-target-qty="0" aria-label="{{ 'cart.general.remove' | t }}">
              {% render 'icon', name: 'trash', size: 16 %}
            </button>
          </div>
        {%- endfor -%}

        {%- if settings.cart_upsell_collection != blank -%}
          {%- liquid
            assign cart_pids = cart.items | map: 'product_id'
            assign shown = 0
          -%}
          {%- capture upsell_html -%}
            {%- for upsell_product in settings.cart_upsell_collection.products limit: 8 -%}
              {%- unless cart_pids contains upsell_product.id or upsell_product.available == false or shown >= 2 -%}
                {%- assign shown = shown | plus: 1 -%}
                <div class="cart-upsell__item">
                  <a href="{{ upsell_product.url }}" class="cart-upsell__media">
                    {%- if upsell_product.featured_media -%}
                      {{ upsell_product.featured_media | image_url: width: 160 | image_tag: sizes: '64px', loading: 'lazy' }}
                    {%- endif -%}
                  </a>
                  <div class="cart-upsell__info">
                    <a href="{{ upsell_product.url }}" class="cart-upsell__title">{{ upsell_product.title }}</a>
                    <span class="cart-upsell__price">{{ upsell_product.price | money }}</span>
                  </div>
                  {%- if upsell_product.variants.size == 1 -%}
                    <button type="button" class="cart-upsell__add" data-quick-add-id="{{ upsell_product.first_available_variant.id }}" aria-label="{{ 'products.product.quick_add' | t }}">
                      {% render 'icon', name: 'plus', size: 16 %}
                    </button>
                  {%- else -%}
                    <a class="cart-upsell__add" href="{{ upsell_product.url }}" aria-label="{{ 'products.product.choose_options' | t }}">
                      {% render 'icon', name: 'arrow-right', size: 16 %}
                    </a>
                  {%- endif -%}
                </div>
              {%- endunless -%}
            {%- endfor -%}
          {%- endcapture -%}
          {%- if upsell_html contains 'cart-upsell__item' -%}
            <div class="cart-upsell">
              <p class="eyebrow">{{ 'cart.upsell.heading' | t }}</p>
              {{ upsell_html }}
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>

      <div class="cart-drawer__foot">
        <div class="cart-drawer__subtotal">
          <span>{{ 'cart.general.subtotal' | t }}</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <p class="cart-drawer__note">{{ 'cart.general.taxes_note' | t }}</p>
        <a href="{{ routes.cart_url }}/checkout" class="btn btn--primary btn--full">
          {% render 'icon', name: 'lock', size: 15 %}
          {{ 'cart.general.checkout' | t }}
        </a>
        <a href="{{ routes.cart_url }}" class="cart-drawer__view-cart">{{ 'cart.general.view_cart' | t }}</a>
      </div>
    {%- endif -%}
  </aside>
</div>

{% schema %}
{
  "name": "Warenkorb-Drawer",
  "class": "section-cart-drawer"
}
{% endschema %}
