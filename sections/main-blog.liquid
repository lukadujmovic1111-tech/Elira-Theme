<section class="section blog-page">
  <div class="container container--wide">
    <div class="section-head section-head--center">
      <div>
        <p class="eyebrow">{{ 'blogs.general.eyebrow' | t }}</p>
        <h1 class="section-title">{{ blog.title }}</h1>
      </div>
    </div>

    {%- paginate blog.articles by 9 -%}
      <div class="blog-grid">
        {%- for article in blog.articles -%}
          <article class="article-card" data-reveal>
            <a href="{{ article.url }}" class="article-card__media">
              {%- if article.image -%}
                {{ article.image
                  | image_url: width: 900
                  | image_tag: widths: '400, 600, 900', sizes: '(min-width: 990px) 33vw, 100vw', loading: 'lazy' }}
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </a>
            <div class="article-card__info">
              <p class="article-card__meta">
                <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%d.%m.%Y' }}</time>
                {%- if article.tags.size > 0 %} · {{ article.tags.first }}{% endif -%}
              </p>
              <h2 class="article-card__title"><a href="{{ article.url }}">{{ article.title }}</a></h2>
              <p class="article-card__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 140 }}</p>
              <a href="{{ article.url }}" class="link-underline">{{ 'blogs.general.read_more' | t }}</a>
            </div>
          </article>
        {%- else -%}
          <p class="section-sub">{{ 'blogs.general.empty' | t }}</p>
        {%- endfor -%}
      </div>
      {% render 'pagination', paginate: paginate %}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog",
  "settings": []
}
{% endschema %}
