{%- liquid
  assign threshold = settings.free_shipping_threshold | default: 0 | times: 100
  assign remaining = threshold | minus: cart.total_price
  if threshold > 0
    assign progress = cart.total_price | times: 100.0 | divided_by: threshold | at_most: 100
  endif
-%}

<section class="section cart-page">
  <div class="container">
    <h1 class="page-title">{{ 'cart.general.title' | t }}</h1>

    {%- if cart.item_count == 0 -%}
      <div class="cart-page__empty">
        {% render 'icon', name: 'bag', size: 48, stroke_width: 1 %}
        <p class="cart-drawer__empty-title">{{ 'cart.general.empty' | t }}</p>
        <p class="cart-drawer__empty-text">{{ 'cart.general.empty_hint' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">{{ 'cart.general.continue_shopping' | t }}</a>
      </div>
    {%- else -%}

      <form action="{{ routes.cart_url }}" method="post" class="cart-page__grid" data-cart-page-form>
        <div class="cart-page__items">
          {%- if threshold > 0 -%}
            <div class="shipping-bar">
              {%- if remaining > 0 -%}
                {%- assign remaining_money = remaining | money -%}
                <p class="shipping-bar__label">{{ 'cart.shipping_bar.remaining_html' | t: amount: remaining_money }}</p>
              {%- else -%}
                <p class="shipping-bar__label shipping-bar__label--unlocked">{% render 'icon', name: 'truck', size: 16 %} {{ 'cart.shipping_bar.unlocked' | t }}</p>
              {%- endif -%}
              <div class="shipping-bar__track">
                <div class="shipping-bar__fill{% if remaining <= 0 %} is-complete{% endif %}" style="width: {{ progress }}%"></div>
              </div>
            </div>
          {%- endif -%}

          {%- for item in cart.items -%}
            <div class="cart-item cart-item--page">
              <a href="{{ item.url }}" class="cart-item__media">
                {%- if item.image -%}
                  {{ item.image | image_url: width: 300 | image_tag: widths: '150, 300', sizes: '110px', loading: 'lazy', alt: item.title }}
                {%- endif -%}
              </a>
              <div class="cart-item__info">
                <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                {%- unless item.product.has_only_default_variant -%}
                  <p class="cart-item__variant">
                    {%- for option in item.options_with_values -%}
                      {{ option.value }}{% unless forloop.last %} / {% endunless %}
                    {%- endfor -%}
                  </p>
                {%- endunless -%}
                <p class="cart-item__unit-price">{{ item.final_price | money }}</p>

                <div class="cart-item__row">
                  <div class="qty-stepper">
                    <button type="button" class="qty-stepper__btn" data-qty-minus aria-label="{{ 'cart.general.decrease' | t }}">{% render 'icon', name: 'minus', size: 13 %}</button>
                    <input
                      type="number"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      min="0"
                      class="qty-stepper__input"
                      aria-label="{{ 'cart.general.quantity' | t }}"
                      data-qty-input>
                    <button type="button" class="qty-stepper__btn" data-qty-plus aria-label="{{ 'cart.general.increase' | t }}">{% render 'icon', name: 'plus', size: 13 %}</button>
                  </div>
                  <div class="cart-item__price">
                    {%- if item.original_line_price != item.final_line_price -%}
                      <s>{{ item.original_line_price | money }}</s>
                    {%- endif -%}
                    <span>{{ item.final_line_price | money }}</span>
                  </div>
                </div>
              </div>
              <a href="{{ item.url_to_remove }}" class="cart-item__remove" aria-label="{{ 'cart.general.remove' | t }}">
                {% render 'icon', name: 'trash', size: 16 %}
              </a>
            </div>
          {%- endfor -%}

          <div class="cart-page__note">
            <label for="CartNote" class="cart-page__note-label">{{ 'cart.general.note_label' | t }}</label>
            <textarea id="CartNote" name="note" rows="3" placeholder="{{ 'cart.general.note_placeholder' | t }}">{{ cart.note }}</textarea>
          </div>
        </div>

        <aside class="cart-summary">
          <h2 class="cart-summary__title">{{ 'cart.general.summary' | t }}</h2>
          <div class="cart-summary__row">
            <span>{{ 'cart.general.subtotal' | t }}</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          {%- if cart.cart_level_discount_applications.size > 0 -%}
            {%- for discount in cart.cart_level_discount_applications -%}
              <div class="cart-summary__row cart-summary__row--discount">
                <span>{{ discount.title }}</span>
                <span>&minus;{{ discount.total_allocated_amount | money }}</span>
              </div>
            {%- endfor -%}
          {%- endif -%}
          <p class="cart-drawer__note">{{ 'cart.general.taxes_note' | t }}</p>

          <button type="submit" name="update" class="btn btn--secondary btn--full">{{ 'cart.general.update' | t }}</button>
          <button type="submit" name="checkout" class="btn btn--primary btn--full">
            {% render 'icon', name: 'lock', size: 15 %}
            {{ 'cart.general.checkout' | t }}
          </button>

          {%- if shop.enabled_payment_types.size > 0 -%}
            <ul class="payment-icons payment-icons--center">
              {%- for type in shop.enabled_payment_types -%}
                <li>{{ type | payment_type_svg_tag: class: 'payment-icon' }}</li>
              {%- endfor -%}
            </ul>
          {%- endif -%}

          <ul class="cart-summary__trust">
            {%- if settings.shipping_note != blank -%}
              <li>{% render 'icon', name: 'truck', size: 16 %} {{ settings.shipping_note }}</li>
            {%- endif -%}
            {%- if settings.returns_note != blank -%}
              <li>{% render 'icon', name: 'returns', size: 16 %} {{ settings.returns_note }}</li>
            {%- endif -%}
            <li>{% render 'icon', name: 'lock', size: 16 %} {{ 'products.product.secure_checkout' | t }}</li>
          </ul>
        </aside>
      </form>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Warenkorbseite",
  "settings": []
}
{% endschema %}
