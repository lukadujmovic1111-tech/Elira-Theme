<section class="section contact-page">
  <div class="container container--narrow">
    <div class="section-head section-head--center">
      <div>
        <p class="eyebrow">{{ 'contact.eyebrow' | t }}</p>
        <h1 class="section-title">{{ section.settings.heading | default: page.title }}</h1>
        {%- if section.settings.text != blank -%}
          <p class="section-sub">{{ section.settings.text }}</p>
        {%- endif -%}
      </div>
    </div>

    {%- form 'contact', class: 'contact-form' -%}
      {%- if form.posted_successfully? -%}
        <p class="form-success">{% render 'icon', name: 'check', size: 16 %} {{ 'contact.success' | t }}</p>
      {%- endif -%}
      {%- if form.errors -%}
        <p class="form-error">{{ 'general.forms.error' | t }}</p>
      {%- endif -%}

      <div class="contact-form__row">
        <div class="form-field">
          <label for="ContactName">{{ 'general.forms.name' | t }}</label>
          <input type="text" id="ContactName" name="contact[name]" autocomplete="name" required>
        </div>
        <div class="form-field">
          <label for="ContactEmail">{{ 'general.forms.email' | t }}</label>
          <input type="email" id="ContactEmail" name="contact[email]" autocomplete="email" required>
        </div>
      </div>
      <div class="form-field">
        <label for="ContactSubject">{{ 'contact.subject' | t }}</label>
        <input type="text" id="ContactSubject" name="contact[subject]">
      </div>
      <div class="form-field">
        <label for="ContactBody">{{ 'contact.message' | t }}</label>
        <textarea id="ContactBody" name="contact[body]" rows="6" required></textarea>
      </div>
      <button type="submit" class="btn btn--primary">{{ 'contact.submit' | t }}</button>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Kontaktformular",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Wir sind für dich da"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Fragen zu Größe, Bestellung oder Rückgabe? Wir antworten in der Regel innerhalb von 24 Stunden."
    }
  ],
  "presets": [
    {
      "name": "Kontaktformular"
    }
  ]
}
{% endschema %}
