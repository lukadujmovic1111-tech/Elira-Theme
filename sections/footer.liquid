<footer class="site-footer">
  <div class="container container--wide">

    <div class="site-footer__top">
      <div class="footer-brand">
        <p class="footer-brand__logo">{{ shop.name }}</p>
        {%- if section.settings.tagline != blank -%}
          <p class="footer-brand__tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}
        <div class="social-links">
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">{% render 'icon', name: 'instagram', size: 19 %}</a>
          {%- endif -%}
          {%- if settings.social_tiktok != blank -%}
            <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">{% render 'icon', name: 'tiktok', size: 19 %}</a>
          {%- endif -%}
          {%- if settings.social_pinterest != blank -%}
            <a href="{{ settings.social_pinterest }}" target="_blank" rel="noopener" aria-label="Pinterest">{% render 'icon', name: 'pinterest', size: 19 %}</a>
          {%- endif -%}
          {%- if settings.social_youtube != blank -%}
            <a href="{{ settings.social_youtube }}" target="_blank" rel="noopener" aria-label="YouTube">{% render 'icon', name: 'youtube', size: 19 %}</a>
          {%- endif -%}
          {%- if settings.social_facebook != blank -%}
            <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook">{% render 'icon', name: 'facebook', size: 19 %}</a>
          {%- endif -%}
        </div>
      </div>

      <div class="footer-menus">
        {%- for block in section.blocks -%}
          {%- if block.type == 'menu' and block.settings.menu != blank -%}
            <nav class="footer-col" {{ block.shopify_attributes }} aria-label="{{ block.settings.heading | escape }}">
              <h3 class="footer-col__heading">{{ block.settings.heading }}</h3>
              <ul class="footer-col__list">
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            </nav>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.show_newsletter -%}
        <div class="footer-newsletter">
          <h3 class="footer-col__heading">{{ section.settings.newsletter_heading }}</h3>
          <p class="footer-newsletter__text">{{ section.settings.newsletter_text }}</p>
          {%- form 'customer', class: 'newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            {%- if form.posted_successfully? -%}
              <p class="form-success">{% render 'icon', name: 'check', size: 16 %} {{ 'general.newsletter.success' | t }}</p>
            {%- else -%}
              <div class="newsletter-form__row">
                <input
                  type="email"
                  name="contact[email]"
                  class="newsletter-form__input"
                  placeholder="{{ 'general.newsletter.placeholder' | t }}"
                  required
                  autocomplete="email"
                  aria-label="{{ 'general.newsletter.placeholder' | t }}">
                <button type="submit" class="newsletter-form__submit" aria-label="{{ 'general.newsletter.submit' | t }}">
                  {% render 'icon', name: 'arrow-right', size: 18 %}
                </button>
              </div>
              {%- if form.errors -%}
                <p class="form-error">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
              {%- endif -%}
            {%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}
    </div>

    <div class="site-footer__bottom">
      <p class="footer-copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'general.footer.rights' | t }}</p>

      {%- if section.settings.show_payment_icons and shop.enabled_payment_types.size > 0 -%}
        <ul class="payment-icons" aria-label="{{ 'general.footer.payment_methods' | t }}">
          {%- for type in shop.enabled_payment_types -%}
            <li>{{ type | payment_type_svg_tag: class: 'payment-icon' }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      <ul class="footer-legal">
        {%- for policy in shop.policies -%}
          {%- if policy != blank -%}
            <li><a href="{{ policy.url }}">{{ policy.title }}</a></li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Marken-Tagline",
      "default": "Bewegung, die sich wie du anfühlt."
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Newsletter anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Überschrift",
      "default": "Bleib in Bewegung"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Text",
      "default": "10 % auf deine erste Bestellung — plus früher Zugang zu neuen Drops."
    },
    {
      "type": "header",
      "content": "Unten"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Zahlungsarten anzeigen",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menü-Spalte",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Überschrift",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menü"
        }
      ]
    }
  ],
  "max_blocks": 4
}
{% endschema %}
