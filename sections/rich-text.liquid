<section class="section rich-text-section{% if section.settings.background == 'bone' %} section--bone{% endif %}">
  <div class="container container--narrow">
    <div class="rich-text-section__inner text-{{ section.settings.alignment }}" data-reveal>
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="section-title section-title--lg">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="rte">{{ section.settings.text }}</div>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="btn btn--secondary">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Text",
  "settings": [
    {
      "type": "select",
      "id": "background",
      "label": "Hintergrund",
      "options": [
        { "value": "white", "label": "Weiß" },
        { "value": "bone", "label": "Bone (Soft)" }
      ],
      "default": "white"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Ausrichtung",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Unsere Philosophie"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Weniger, aber besser"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Elira steht für durchdachte Essentials statt schneller Trends: wenige, perfekt geschnittene Pieces, die du jahrelang trägst — im Studio, im Alltag, überall dazwischen.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button-Text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button-Link"
    }
  ],
  "presets": [
    {
      "name": "Text"
    }
  ]
}
{% endschema %}
