<section class="section featured-collection{% if section.settings.background == 'bone' %} section--bone{% endif %}">
  <div class="container container--wide">
    <div class="section-head" data-reveal>
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="section-title">{{ section.settings.heading }}</h2>
      </div>
      <div class="section-head__actions">
        {%- if section.settings.show_view_all and section.settings.collection != blank -%}
          <a href="{{ section.settings.collection.url }}" class="link-underline">{{ 'general.navigation.view_all' | t }}</a>
        {%- endif -%}
        <div class="scroller-nav">
          <button type="button" class="scroller-nav__btn" data-scroll-prev aria-label="{{ 'general.slider.previous' | t }}" disabled>
            {% render 'icon', name: 'chevron-left', size: 18 %}
          </button>
          <button type="button" class="scroller-nav__btn" data-scroll-next aria-label="{{ 'general.slider.next' | t }}">
            {% render 'icon', name: 'chevron-right', size: 18 %}
          </button>
        </div>
      </div>
    </div>

    <div class="product-scroller" data-scroller data-reveal data-reveal-stagger>
      {%- if section.settings.collection != blank -%}
        {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
          <div class="product-scroller__slide">
            {% render 'product-card',
              card_product: product,
              placeholder_index: forloop.index0,
              sizes: '(min-width: 990px) 24vw, 72vw' %}
          </div>
        {%- else -%}
          {%- for i in (1..4) -%}
            <div class="product-scroller__slide">
              {% render 'product-card', card_product: blank, placeholder_index: forloop.index0 %}
            </div>
          {%- endfor -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="product-scroller__slide">
            {% render 'product-card', card_product: blank, placeholder_index: forloop.index0 %}
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Produkt-Slider",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Von der Community geliebt"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Unsere Bestseller"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Kollektion"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Anzahl Produkte",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "\"Alle ansehen\" anzeigen",
      "default": true
    },
    {
      "type": "select",
      "id": "background",
      "label": "Hintergrund",
      "options": [
        { "value": "white", "label": "Weiß" },
        { "value": "bone", "label": "Bone (Soft)" }
      ],
      "default": "white"
    }
  ],
  "presets": [
    {
      "name": "Produkt-Slider"
    }
  ]
}
{% endschema %}
