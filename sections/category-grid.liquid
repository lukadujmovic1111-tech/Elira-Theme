<section class="section category-grid">
  <div class="container container--wide">
    <div class="section-head" data-reveal>
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="section-title">{{ section.settings.heading }}</h2>
      </div>
    </div>

    <div class="category-grid__grid category-grid__grid--{{ section.blocks.size | at_most: 6 }}" data-reveal data-reveal-stagger>
      {%- for block in section.blocks -%}
        {%- liquid
          assign tile_collection = block.settings.collection
          assign tile_title = block.settings.title
          if tile_title == blank
            assign tile_title = tile_collection.title
          endif
          if tile_title == blank
            assign tile_title = 'onboarding.collection_title' | t
          endif
          assign tile_image = block.settings.image
          if tile_image == blank
            assign tile_image = tile_collection.featured_image
          endif
          assign pidx = forloop.index0 | modulo: 4 | plus: 1
        -%}
        <a href="{{ tile_collection.url | default: routes.all_products_collection_url }}" class="category-tile" {{ block.shopify_attributes }}>
          <div class="category-tile__media">
            {%- if tile_image != blank -%}
              {{ tile_image
                | image_url: width: 1100
                | image_tag:
                  widths: '400, 600, 800, 1100',
                  sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 60vw',
                  loading: 'lazy' }}
            {%- else -%}
              {{ 'collection-apparel-' | append: pidx | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="category-tile__label">
            <span class="category-tile__title">{{ tile_title }}</span>
            <span class="category-tile__arrow">{% render 'icon', name: 'arrow-right', size: 16 %}</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kategorie-Grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Finde deinen Flow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Shop nach Kategorie"
    }
  ],
  "max_blocks": 6,
  "blocks": [
    {
      "type": "category",
      "name": "Kategorie",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Kollektion"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel (überschreibt Kollektionsnamen)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bild (überschreibt Kollektionsbild)",
          "info": "Empfohlen: 900 × 1200 px"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kategorie-Grid",
      "blocks": [
        { "type": "category", "settings": { "title": "Leggings" } },
        { "type": "category", "settings": { "title": "Yoga" } },
        { "type": "category", "settings": { "title": "Pilates" } },
        { "type": "category", "settings": { "title": "Sets" } },
        { "type": "category", "settings": { "title": "Sport-BHs" } },
        { "type": "category", "settings": { "title": "Kleider" } }
      ]
    }
  ]
}
{% endschema %}
