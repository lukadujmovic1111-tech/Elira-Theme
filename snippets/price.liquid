{%- comment -%}
  Rendert Preise inkl. Sale-Logik.
  Parameter:
    product: product-Objekt (optional, wenn variant gesetzt)
    variant: variant-Objekt (optional, hat Vorrang)
    class:   zusätzliche CSS-Klasse
    show_badge: true → "-XX%" Badge hinter dem Preis
{%- endcomment -%}
{%- liquid
  if variant
    assign price = variant.price
    assign compare_at = variant.compare_at_price
    assign price_varies = false
  else
    assign price = product.price | default: 0
    assign compare_at = product.compare_at_price
    assign price_varies = product.price_varies
  endif

  assign money_price = price | money
  assign on_sale = false
  if compare_at > price
    assign on_sale = true
    assign money_compare = compare_at | money
    assign saving = compare_at | minus: price | times: 100.0 | divided_by: compare_at | round
  endif
-%}
<div class="price {{ class }}{% if on_sale %} price--sale{% endif %}">
  {%- if price_varies -%}
    <span class="price__current">{{ 'products.product.from_price_html' | t: price: money_price }}</span>
  {%- else -%}
    <span class="price__current">{{ money_price }}</span>
  {%- endif -%}
  {%- if on_sale -%}
    <s class="price__compare">{{ money_compare }}</s>
    {%- if show_badge -%}
      <span class="price__badge">&minus;{{ saving }}%</span>
    {%- endif -%}
  {%- endif -%}
</div>
