{%- comment -%}
  Premium-Produktkarte.
  Parameter:
    card_product:      product-Objekt (blank → Onboarding-Platzhalter)
    placeholder_index: Zahl für abwechselnde Platzhalter-Grafiken
    sizes:             sizes-Attribut für responsive Bilder
{%- endcomment -%}
{%- liquid
  assign sizes_attr = sizes | default: '(min-width: 990px) 25vw, 50vw'
  assign pidx = placeholder_index | default: 0 | modulo: 4 | plus: 1
-%}

{%- if card_product == blank -%}
  <article class="product-card product-card--placeholder">
    <div class="card-media-wrap">
      <div class="card-media">
        {{ 'product-apparel-' | append: pidx | placeholder_svg_tag: 'card-img placeholder-svg' }}
      </div>
    </div>
    <div class="card-info">
      <h3 class="card-title">{{ 'onboarding.product_title' | t }}</h3>
      <p class="card-type">{{ 'onboarding.product_type' | t }}</p>
      <div class="price"><span class="price__current">{{ 6900 | money }}</span></div>
    </div>
  </article>

{%- else -%}
  {%- liquid
    assign color_option = blank
    for option in card_product.options_with_values
      assign oname = option.name | downcase
      if oname == 'farbe' or oname == 'color' or oname == 'colour'
        assign color_option = option
      endif
    endfor

    assign on_sale = false
    if card_product.compare_at_price > card_product.price
      assign on_sale = true
      assign saving = card_product.compare_at_price | minus: card_product.price | times: 100.0 | divided_by: card_product.compare_at_price | round
    endif

    assign tags_dc = card_product.tags | join: ',' | downcase
  -%}

  <article class="product-card" data-product-card>
    <div class="card-media-wrap">
      <a href="{{ card_product.url }}" class="card-media{% if settings.card_show_secondary_image and card_product.media.size > 1 %} has-secondary{% endif %}" aria-label="{{ card_product.title | escape }}">
        {%- if card_product.featured_media -%}
          {{ card_product.featured_media
            | image_url: width: 900
            | image_tag:
              widths: '320, 480, 640, 900',
              sizes: sizes_attr,
              class: 'card-img card-img--primary',
              loading: 'lazy' }}
          {%- if settings.card_show_secondary_image and card_product.media.size > 1 -%}
            {{ card_product.media[1]
              | image_url: width: 900
              | image_tag:
                widths: '320, 480, 640, 900',
                sizes: sizes_attr,
                class: 'card-img card-img--secondary',
                loading: 'lazy' }}
          {%- endif -%}
        {%- else -%}
          {{ 'product-apparel-' | append: pidx | placeholder_svg_tag: 'card-img placeholder-svg' }}
        {%- endif -%}
      </a>

      {%- if on_sale -%}
        <span class="card-badge card-badge--sale">&minus;{{ saving }}%</span>
      {%- elsif tags_dc contains 'neu' or tags_dc contains 'new' -%}
        <span class="card-badge">{{ 'products.product.badge_new' | t }}</span>
      {%- elsif tags_dc contains 'bestseller' -%}
        <span class="card-badge">{{ 'products.product.badge_bestseller' | t }}</span>
      {%- endif -%}

      {%- unless card_product.available -%}
        <span class="card-badge card-badge--soldout">{{ 'products.product.sold_out' | t }}</span>
      {%- endunless -%}

      {%- if settings.card_show_quick_add and card_product.available -%}
        <div class="card-quick">
          {%- if card_product.variants.size == 1 -%}
            <button type="button" class="card-quick__btn" data-quick-add-id="{{ card_product.first_available_variant.id }}">
              {% render 'icon', name: 'plus', size: 14 %}
              <span>{{ 'products.product.quick_add' | t }}</span>
            </button>
          {%- elsif card_product.options.size == 1 -%}
            <button type="button" class="card-quick__btn" data-quick-toggle aria-expanded="false">
              {% render 'icon', name: 'plus', size: 14 %}
              <span>{{ 'products.product.quick_add' | t }}</span>
            </button>
            <div class="card-quick__options" hidden>
              <p class="card-quick__label">{{ card_product.options.first }}</p>
              <div class="card-quick__pills">
                {%- for variant in card_product.variants -%}
                  <button type="button" class="card-quick__pill" data-quick-add-id="{{ variant.id }}"{% unless variant.available %} disabled{% endunless %}>{{ variant.title }}</button>
                {%- endfor -%}
              </div>
            </div>
          {%- else -%}
            <a class="card-quick__btn" href="{{ card_product.url }}">
              {% render 'icon', name: 'plus', size: 14 %}
              <span>{{ 'products.product.choose_options' | t }}</span>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div class="card-info">
      {%- if settings.card_show_swatches and color_option != blank -%}
        <div class="card-swatches" aria-label="{{ color_option.name }}">
          {%- for value in color_option.values limit: 4 -%}
            {%- capture swatch_bg %}{% render 'color-swatch', value: value %}{% endcapture -%}
            <span class="swatch swatch--xs" title="{{ value | escape }}" style="background: {{ swatch_bg | strip }};"></span>
          {%- endfor -%}
          {%- if color_option.values.size > 1 -%}
            <span class="card-swatches__more">{{ 'products.product.color_count' | t: count: color_option.values.size }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      <h3 class="card-title"><a href="{{ card_product.url }}">{{ card_product.title }}</a></h3>
      {%- if card_product.type != blank -%}
        <p class="card-type">{{ card_product.type }}</p>
      {%- endif -%}
      {% render 'price', product: card_product, class: 'price--card' %}
    </div>
  </article>
{%- endif -%}
