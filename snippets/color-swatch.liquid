{%- comment -%}
  Gibt den CSS-Hintergrund für einen Farbnamen aus (deutsch + englisch).
  Parameter: value (Farbname als String)
  Ausgabe: style-Wert, z. B. "#1B1A18" oder ein Gradient.
{%- endcomment -%}
{%- liquid
  assign v = value | downcase | strip
  assign bg = ''

  case v
    when 'schwarz', 'black', 'onyx'
      assign bg = '#1d1c1a'
    when 'weiß', 'weiss', 'white', 'ivory', 'elfenbein'
      assign bg = '#f7f6f3'
    when 'creme', 'cream', 'ecru', 'vanilla', 'vanille'
      assign bg = '#efe9dd'
    when 'sand', 'beige', 'oat', 'hafer'
      assign bg = '#d9cdb8'
    when 'taupe', 'greige'
      assign bg = '#b3a695'
    when 'mokka', 'mocha', 'kakao', 'cocoa'
      assign bg = '#8a6f5c'
    when 'espresso', 'braun', 'brown', 'schoko'
      assign bg = '#5b4636'
    when 'salbei', 'sage', 'salbeigrün'
      assign bg = '#a8b39a'
    when 'olive', 'oliv', 'olivgrün'
      assign bg = '#74785a'
    when 'tanne', 'forest', 'dunkelgrün', 'pine'
      assign bg = '#3d4f42'
    when 'mint', 'minze'
      assign bg = '#cfe0d4'
    when 'eukalyptus', 'eucalyptus'
      assign bg = '#9eb5a6'
    when 'rosé', 'rose', 'rosa', 'pink', 'blush'
      assign bg = '#e8c9c6'
    when 'altrosa', 'dusty rose', 'mauve'
      assign bg = '#c79f9d'
    when 'terracotta', 'terrakotta', 'clay', 'rust'
      assign bg = '#b3674c'
    when 'bordeaux', 'burgundy', 'wein', 'wine', 'cherry'
      assign bg = '#6e2e35'
    when 'rot', 'red'
      assign bg = '#b03a2e'
    when 'koralle', 'coral', 'peach', 'pfirsich'
      assign bg = '#e8a087'
    when 'lavendel', 'lavender', 'flieder', 'lilac'
      assign bg = '#c5bcd6'
    when 'pflaume', 'plum', 'aubergine'
      assign bg = '#5d4157'
    when 'himmelblau', 'sky', 'sky blue', 'hellblau'
      assign bg = '#b9cfdd'
    when 'blau', 'blue', 'kobalt', 'cobalt'
      assign bg = '#39598f'
    when 'navy', 'marine', 'dunkelblau', 'mitternacht', 'midnight'
      assign bg = '#232c3d'
    when 'petrol', 'teal'
      assign bg = '#2f5d62'
    when 'grau', 'grey', 'gray'
      assign bg = '#9a9a96'
    when 'hellgrau', 'heather grey', 'graumeliert'
      assign bg = '#c9c9c5'
    when 'anthrazit', 'charcoal', 'graphit', 'graphite'
      assign bg = '#46464a'
    when 'silber', 'silver'
      assign bg = '#c7c9cc'
    when 'gold'
      assign bg = '#c9a96a'
    when 'senf', 'mustard', 'ocker', 'ochre'
      assign bg = '#c2913e'
    when 'gelb', 'yellow', 'butter'
      assign bg = '#e9d48a'
    when 'leopard', 'leo', 'animal'
      assign bg = 'radial-gradient(circle at 30% 30%, #c8a06a 25%, #6e4f2e 27%, #c8a06a 33%)'
    when 'multi', 'mehrfarbig', 'print', 'gemustert'
      assign bg = 'conic-gradient(#d9cdb8, #a8b39a, #c79f9d, #39598f, #d9cdb8)'
  endcase

  unless bg != ''
    assign bg = '#cbc5ba'
  endunless
-%}{{ bg }}
