<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }}</title>
  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@1,500&display=swap" rel="stylesheet">
  {% style %}
    :root {
      --c-ink: {{ settings.color_ink | default: '#111111' }};
      --c-body: {{ settings.color_body | default: '#3F3F3F' }};
      --c-accent: {{ settings.color_accent | default: '#111111' }};
      --c-bone: {{ settings.color_bone | default: '#F5F5F5' }};
      --c-sale: {{ settings.color_sale | default: '#B3261E' }};
      --c-accent-soft: {{ settings.color_accent | default: '#111111' | color_mix: '#FFFFFF', 10 }};
      --c-ink-soft: {{ settings.color_ink | default: '#111111' | color_modify: 'alpha', 0.55 }};
    }
  {% endstyle %}
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
</head>
<body class="template-password">
  <main id="MainContent" role="main">
    {{ content_for_layout }}
  </main>
</body>
</html>
